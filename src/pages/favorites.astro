---
export const prerender = false;
import Layout from '~/layouts/Layout.astro';
import TopBar from '~/components/TopBar.astro';
import { getPhotos } from '~/lib/photos';

const photos = await getPhotos();
const favorites = photos.filter((p) => p.favorite);
favorites.sort((a, b) => (b.datetime || '').localeCompare(a.datetime || ''));
---
<Layout title="⭐ Favorites · Photo Portfolio" description={`${favorites.length} favorites`}>
  <div class="app-shell">
    <TopBar photos={photos} active="map" />
    <main class="favs-main">
      <header class="favs-header">
        <h1>⭐ Favorites</h1>
        <p class="favs-sub">{favorites.length} {favorites.length === 1 ? 'photo' : 'photos'}</p>
      </header>
      {favorites.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">⭐</div>
          <p class="empty-title">No favorites yet</p>
          {/* Visitors and admin see different next-step copy. CSS hides
              the irrelevant line based on body.logged-in. */}
          <p class="empty-hint logged-out-only">
            The curator hasn't pinned anything here yet — try the
            <a href="/">map</a> or <a href="/timeline">timeline</a> instead.
          </p>
          <p class="empty-hint logged-in-only">
            Open any photo and tap the ☆ in its info bar to add it here.
          </p>
        </div>
      ) : (
        <div class="favs-grid">
          {favorites.map((p) => (
            <a href={`/photos/${p.id}`} class="fav-card" title={p.path}>
              <img
                loading="lazy"
                src={p.thumbs.s}
                data-large={p.thumbs.m}
                alt=""
                onload="this.classList.add('loaded')"
              />
              <div class="info">
                <span class="flag">⭐</span>
                <span class="meta">
                  {p.country || ''}{p.datetime && ` · ${p.datetime.slice(0, 10)}`}
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </main>
  </div>
</Layout>

<style is:global>
  .favs-main {
    flex: 1;
    overflow-y: auto;
    padding: 32px 48px 80px;
  }
  .favs-header { margin-bottom: 24px; }
  .favs-header h1 {
    font-size: 32px;
    font-weight: 800;
    margin: 0 0 4px;
    letter-spacing: -0.02em;
  }
  .favs-sub { color: var(--muted); margin: 0; font-size: 13px; }

  .favs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }
  .fav-card {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 6px;
    overflow: hidden;
    background: #ddd;
    color: inherit;
    text-decoration: none;
  }
  .fav-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s, transform 0.4s;
    opacity: 0.0;
  }
  .fav-card img.loaded { opacity: 1; }
  .fav-card:hover img { transform: scale(1.03); }
  .fav-card .info {
    position: absolute;
    inset: auto 0 0 0;
    padding: 8px 12px;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
    color: white;
    font-size: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .fav-card .flag { font-size: 16px; }
  .empty-state {
    padding: 100px 20px;
    text-align: center;
    color: var(--muted);
    max-width: 480px;
    margin: 0 auto;
  }
  .empty-state .empty-icon {
    font-size: 64px;
    margin-bottom: 14px;
    opacity: 0.55;
  }
  .empty-state .empty-title {
    font-size: 20px;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 6px;
  }
  .empty-state .empty-hint {
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
  }
  .empty-state .empty-hint a { color: var(--accent); }
</style>
