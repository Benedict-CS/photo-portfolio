---
export const prerender = false;
import Layout from '~/layouts/Layout.astro';
import TopBar from '~/components/TopBar.astro';
import { getPhotos } from '~/lib/photos';

const photos = await getPhotos();
const favorites = photos.filter((p) => p.favorite);
favorites.sort((a, b) => (b.datetime || '').localeCompare(a.datetime || ''));
---
<Layout title="⭐ Favorites · Photo Portfolio" description={`${favorites.length} favorites`}>
  <div class="app-shell">
    <TopBar photos={photos} active="favorites" />
    <main class="favs-main">
      <header class="favs-header">
        <h1>⭐ Favorites</h1>
        <p class="favs-sub">{favorites.length} {favorites.length === 1 ? 'photo' : 'photos'}</p>
      </header>
      {favorites.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">⭐</div>
          <p class="empty-title">No favorites yet</p>
          {/* Visitors and admin see different next-step copy. CSS hides
              the irrelevant line based on body.logged-in. */}
          <p class="empty-hint logged-out-only">
            The curator hasn't pinned anything here yet — try the
            <a href="/">map</a> or <a href="/timeline">timeline</a> instead.
          </p>
          <p class="empty-hint logged-in-only">
            Open any photo and tap the ☆ in its info bar to add it here.
          </p>
        </div>
      ) : (
        <div class="favs-grid">
          {favorites.map((p) => (
            <a href={`/photos/${p.id}`} class={`fav-card${p.kind === 'video' ? ' is-video' : ''}`} title={p.path}>
              <img
                loading="lazy"
                src={p.thumbs.s}
                data-large={p.thumbs.m}
                alt=""
                onload="this.classList.add('loaded')"
              />
              <div class="info">
                <span class="flag">⭐</span>
                <span class="meta">
                  {p.country || ''}{p.datetime && ` · ${p.datetime.slice(0, 10)}`}
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </main>
  </div>
</Layout>

<style is:global>
  .favs-main {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-6) var(--space-7) var(--space-8);
  }
  .favs-header { margin-bottom: var(--space-5); }
  .favs-header h1 {
    font-size: var(--text-3xl);
    font-weight: 800;
    margin: 0 0 var(--space-1);
    letter-spacing: -0.02em;
  }

  @media (max-width: 720px) {
    .favs-main { padding: var(--space-5) var(--space-4) var(--space-7); }
    .favs-header h1 { font-size: var(--text-2xl); }
  }
  .favs-sub { color: var(--muted); margin: 0; font-size: 13px; }

  .favs-grid {
    display: grid;
    /* min() prevents the 220 px floor from forcing horizontal scroll on
       phones — collapses to a single full-width column when the viewport
       can't hold a 220 px card. */
    grid-template-columns: repeat(auto-fill, minmax(min(220px, 100%), 1fr));
    gap: 12px;
  }
  .fav-card {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s var(--ease-out), box-shadow 0.2s;
    /* Skeleton shimmer until the actual photo loads — gives the empty
       card visual interest instead of a flat gray rectangle. The
       `.loaded` class on the inner img switches the background off
       once the photo paints. */
    background:
      linear-gradient(110deg,
        #e8e8e8 0%, #f4f4f4 40%, #e8e8e8 80%) #e8e8e8;
    background-size: 200% 100%;
    animation: card-shimmer 1.6s ease-in-out infinite;
  }
  .fav-card:has(img.loaded) {
    animation: none;
    background: #eaeaea;
  }
  .fav-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  @keyframes card-shimmer {
    0%   { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .fav-card { animation: none; background: #eaeaea; }
  }
  .fav-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s, transform 0.4s;
    opacity: 0.0;
  }
  .fav-card img.loaded { opacity: 1; }
  .fav-card:hover img { transform: scale(1.03); }
  .fav-card .info {
    position: absolute;
    inset: auto 0 0 0;
    padding: 8px 12px;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
    color: white;
    font-size: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .fav-card .flag { font-size: 16px; }
  /* .empty-state lives in global.css now (shared with /timeline). */
</style>
