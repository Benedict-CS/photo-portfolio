---
export const prerender = false;
import Layout from '~/layouts/Layout.astro';
import TopBar from '~/components/TopBar.astro';
import Lightbox from '~/components/Lightbox.astro';
import { getPhotos, type PhotoView as Photo } from '~/lib/photos';

const photos = await getPhotos();

// --- Group: country -> "YYYY-MM" -> Photo[] ---
type MonthGroup = { ym: string; monthLabel: string; photos: Photo[] };
type CountryGroup = { country: string; countryCode: string; count: number; months: MonthGroup[] };

const byCountry = new Map<string, CountryGroup>();
for (const p of photos) {
  const ckey = p.country || '未知';
  let g = byCountry.get(ckey);
  if (!g) {
    g = { country: ckey, countryCode: p.countryCode, count: 0, months: [] };
    byCountry.set(ckey, g);
  }
  g.count++;
  const ym = (p.datetime || '').slice(0, 7) || 'unknown';
  let m = g.months.find((x) => x.ym === ym);
  if (!m) {
    const monthLabel = ym === 'unknown'
      ? '未知時間'
      : `${ym.slice(0, 4)}年${parseInt(ym.slice(5, 7), 10)}月`;
    m = { ym, monthLabel, photos: [] };
    g.months.push(m);
  }
  m.photos.push(p);
}

// Sort by photo count descending, but always pin 未定位 to the end so it
// doesn't break up the "real" countries in the rail.
const countries = [...byCountry.values()].sort((a, b) => {
  if (a.country === '未定位') return 1;
  if (b.country === '未定位') return -1;
  return b.count - a.count;
});
for (const c of countries) {
  c.months.sort((a, b) => {
    // Pin "unknown" (未知時間) to the bottom regardless of how the country is ordered.
    if (a.ym === 'unknown') return 1;
    if (b.ym === 'unknown') return -1;
    return b.ym.localeCompare(a.ym);
  });
  for (const m of c.months) {
    m.photos.sort((a, b) => (b.datetime || '').localeCompare(a.datetime || ''));
  }
}

function flagEmoji(code: string) {
  // 📍 signals "needs a location pinned" for the 未定位 bucket.
  if (!code || code.length !== 2) return '📍';
  return String.fromCodePoint(
    ...[...code.toLowerCase()].map((c) => 0x1f1e6 + (c.charCodeAt(0) - 97))
  );
}

const sectionId = (country: string) =>
  'c-' + country.replace(/[^\w一-鿿]/g, '-');
---
<Layout title="📸 Photo Portfolio · Timeline">
  <div class="app-shell">
    <TopBar photos={photos} active="timeline" />
    <main class="timeline-main">
      <button id="rail-toggle" type="button" aria-label="切換國家欄" title="切換國家欄 (`)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <aside class="country-rail" aria-label="國家導覽">
        {countries.map((c) => (
          <a class="rail-item" href={`#${sectionId(c.country)}`} data-country={c.country} title={c.country}>
            <span class="rail-flag">{flagEmoji(c.countryCode)}</span>
            <span class="rail-name">{c.country}</span>
            <span class="rail-code">{c.countryCode ? c.countryCode.toUpperCase() : '未'}</span>
            <span class="rail-count">{c.count}</span>
          </a>
        ))}
      </aside>

      <div class="timeline-feed">
        <div class="select-hint edit-only">
          <kbd>Ctrl/Cmd</kbd> + 點選 多選照片 · <kbd>Shift</kbd> + 點選 範圍選 · 選好後底部出現「⭐ 加入收藏」
        </div>
        {countries.length === 0 ? (
          <div class="empty-state">
            <p>沒有照片。請在 Nextcloud 分享資料夾裡上傳含 GPS 的 JPEG。</p>
          </div>
        ) : (
          countries.map((c) => (
            <section class="country-section" id={sectionId(c.country)} data-country={c.country}>
              <header class="country-header">
                <div class="hero-flag">{flagEmoji(c.countryCode)}</div>
                <div class="hero-meta">
                  <h2 class="hero-name">{c.country}</h2>
                  <div class="hero-sub">{c.count} 張</div>
                </div>
              </header>
              {c.months.map((m) => (
                <div class="month-block">
                  <h3 class="month-label">{m.monthLabel}<span class="month-count"> · {m.photos.length}</span></h3>
                  <div
                    class="justified-grid"
                    data-photos={JSON.stringify(m.photos.map((p) => ({
                      id: p.id,
                      path: p.path,
                      thumb_s: p.thumbs.s,
                      thumb_m: p.thumbs.m,
                      thumb_l: p.thumbs.l,
                      placeholder: p.placeholder,
                      datetime: p.datetime,
                      editable: p.editable,
                    })))}
                  ></div>
                </div>
              ))}
            </section>
          ))
        )}
      </div>
    </main>
    <div id="batch-bar" class="edit-only">
      <span class="count">已選 0 張</span>
      <button id="batch-favorite" type="button">⭐ 加入收藏</button>
      <button id="batch-clear" type="button">清除</button>
    </div>
  </div>
  <Lightbox />
</Layout>

<style is:global>
  .timeline-main {
    flex: 1;
    overflow: hidden;
    display: grid;
    grid-template-columns: 180px 1fr;
    min-height: 0;
    transition: grid-template-columns 0.22s ease;
    position: relative;
  }
  .timeline-main.rail-collapsed { grid-template-columns: 56px 1fr; }

  #rail-toggle {
    position: absolute;
    top: 14px;
    left: 166px;
    z-index: 1100;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--panel);
    cursor: pointer;
    color: var(--muted);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    transition: left 0.22s ease, transform 0.22s ease, color 0.15s;
  }
  #rail-toggle:hover { color: var(--text); background: #f5f5f5; }
  .timeline-main.rail-collapsed #rail-toggle {
    left: 42px;
    transform: rotate(180deg);
  }

  /* ---- Left country rail ---- */
  .country-rail {
    border-right: 1px solid var(--border);
    padding: 24px 0;
    overflow-y: auto;
    background: var(--panel);
  }
  .rail-item {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    align-items: center;
    gap: 10px;
    padding: 9px 18px;
    color: var(--text);
    border-left: 3px solid transparent;
    font-size: 14px;
    cursor: pointer;
  }
  .rail-item:hover { background: #f5f5f5; text-decoration: none; }
  .rail-item.active {
    background: var(--accent-bg);
    border-left-color: var(--accent);
    color: var(--accent);
    font-weight: 600;
  }
  .rail-flag { font-size: 20px; line-height: 1; }
  .rail-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rail-code { display: none; font-size: 11px; font-weight: 600; color: var(--muted); }
  .rail-count {
    font-size: 11px;
    color: var(--muted);
    background: #f0f0f0;
    padding: 1px 7px;
    border-radius: 999px;
  }
  .rail-item.active .rail-count { background: var(--accent); color: white; }

  /* ---- Collapsed (mini) rail: country code only ---- */
  .timeline-main.rail-collapsed .rail-item {
    grid-template-columns: 1fr;
    justify-items: center;
    padding: 10px 4px;
    border-left-width: 0;
    border-right: 3px solid transparent;
    font-weight: 600;
  }
  .timeline-main.rail-collapsed .rail-item.active {
    border-left-width: 0;
    border-right-color: var(--accent);
  }
  .timeline-main.rail-collapsed .rail-flag,
  .timeline-main.rail-collapsed .rail-name,
  .timeline-main.rail-collapsed .rail-count { display: none; }
  .timeline-main.rail-collapsed .rail-code {
    display: block;
    font-size: 13px;
    color: var(--text);
  }
  .timeline-main.rail-collapsed .rail-item.active .rail-code { color: var(--accent); }

  /* ---- Feed ---- */
  .timeline-feed {
    overflow-y: auto;
    padding: 32px 48px 120px;
    scroll-behavior: smooth;
    background: var(--bg);
  }

  .country-section {
    margin-bottom: 64px;
    scroll-margin-top: 20px;
  }
  .country-section:last-child { margin-bottom: 40px; }

  .country-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .hero-flag {
    font-size: 56px;
    line-height: 1;
    width: 64px;
    text-align: center;
  }
  .hero-meta { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .hero-name {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }
  .hero-sub {
    font-size: 13px;
    color: var(--muted);
  }

  .month-block {
    margin-bottom: 32px;
    content-visibility: auto;
    contain-intrinsic-size: 1px 400px;
  }
  .month-label {
    font-size: 13px;
    color: var(--muted);
    font-weight: 500;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
  }
  .month-count { color: var(--muted); font-weight: 400; }

  .justified-grid { display: flex; flex-wrap: wrap; gap: 4px; }
  .justified-cell {
    position: relative;
    overflow: hidden;
    border-radius: 2px;
    background: #e5e5e5;
    cursor: zoom-in;
    flex-shrink: 0;
    transition: transform 0.18s;
  }
  .justified-cell:hover { transform: translateY(-2px); }
  .justified-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s;
  }
  .justified-cell:hover img { transform: scale(1.04); }
  .justified-cell .date-tag {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: rgba(0, 0, 0, 0.6);
    color: white;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 4px;
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
    backdrop-filter: blur(4px);
  }
  .justified-cell:hover .date-tag { opacity: 1; }

  /* Selection mode */
  .justified-cell.selected {
    outline: 3px solid var(--accent);
    outline-offset: -3px;
    transform: scale(0.96);
  }
  .justified-cell.selected::after {
    content: '✓';
    position: absolute;
    top: 8px;
    left: 8px;
    width: 24px;
    height: 24px;
    background: var(--accent);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    box-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  /* Bottom batch-action bar */
  #batch-bar {
    position: fixed;
    bottom: 18px;
    left: 50%;
    transform: translate(-50%, 80px);
    z-index: 1000;
    background: rgba(20, 20, 20, 0.96);
    color: white;
    border-radius: 999px;
    padding: 8px 8px 8px 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.45);
    backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.25s cubic-bezier(0.2, 0.9, 0.3, 1), opacity 0.18s;
    font-size: 13px;
  }
  #batch-bar.show {
    transform: translate(-50%, 0);
    opacity: 1;
    pointer-events: auto;
  }
  #batch-bar .count { font-weight: 600; }
  #batch-bar button {
    background: rgba(255,255,255,0.15);
    color: white;
    border: none;
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
    font-size: 12px;
    font-family: inherit;
  }
  #batch-bar button:hover { background: rgba(255,255,255,0.25); }
  #batch-bar button.primary { background: var(--accent); }
  #batch-bar button.primary:hover { background: #024fa1; }

  .select-hint {
    background: #f3f4f6;
    color: var(--muted);
    font-size: 12px;
    padding: 8px 14px;
    border-radius: 6px;
    margin-bottom: 24px;
  }
  .select-hint kbd {
    background: white;
    border: 1px solid var(--border);
    border-bottom-width: 2px;
    border-radius: 4px;
    padding: 1px 6px;
    font-family: ui-monospace, monospace;
    font-size: 11px;
    color: var(--text);
  }

  .empty-state { padding: 80px 20px; text-align: center; color: var(--muted); }

  @media (max-width: 720px) {
    .timeline-main { grid-template-columns: 1fr; }
    .country-rail {
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 8px 12px;
      display: flex;
      gap: 6px;
      overflow-x: auto;
    }
    .rail-item {
      display: inline-flex;
      grid-template-columns: none;
      padding: 5px 11px;
      border: 1px solid var(--border);
      border-left-width: 1px;
      border-radius: 999px;
      flex-shrink: 0;
    }
    .rail-item.active {
      border-color: var(--accent);
      background: var(--accent-bg);
    }
    .timeline-feed { padding: 24px 16px 80px; }
    .hero-flag { font-size: 40px; }
    .hero-name { font-size: 28px; }
  }
</style>

<script>
  // ---- Country-rail collapse (persisted) ----
  const RAIL_COLLAPSE_KEY = 'timeline-rail-collapsed';
  const main = document.querySelector('.timeline-main') as HTMLElement;
  const toggle = document.getElementById('rail-toggle');
  if (main && localStorage.getItem(RAIL_COLLAPSE_KEY) === '1') {
    main.classList.add('rail-collapsed');
  }
  toggle?.addEventListener('click', () => {
    if (!main) return;
    main.classList.toggle('rail-collapsed');
    const collapsed = main.classList.contains('rail-collapsed');
    localStorage.setItem(RAIL_COLLAPSE_KEY, collapsed ? '1' : '0');
    setTimeout(() => setupGrids(), 250); // re-flow after transition
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === '`' && (e.target as HTMLElement).tagName !== 'INPUT' && (e.target as HTMLElement).tagName !== 'TEXTAREA') {
      toggle?.click();
    }
  });

  // ---- Justified row layout ----
  const TARGET_ROW_HEIGHT = 220;
  const ROW_GAP = 4;

  function layoutGrid(container: HTMLElement, photos: any[]) {
    container.innerHTML = '';
    const width = container.clientWidth;
    if (!width || !photos.length) return;

    const cells: { p: any; ratio: number; el: HTMLDivElement; img: HTMLImageElement }[] = [];
    photos.forEach((p) => {
      const cell = document.createElement('div');
      cell.className = 'justified-cell lqip';
      cell.dataset.id = p.id;
      if (p.placeholder) cell.style.backgroundImage = `url("${p.placeholder}")`;
      const img = document.createElement('img');
      img.loading = 'lazy';
      // Progressive: load the tiny 200px (square crop) first — usually arrives
      // in one TCP packet — then upgrade to the 400px once it's in cache.
      img.src = p.thumb_s;
      img.alt = '';
      img.dataset.large = p.thumb_l;
      img.dataset.medium = p.thumb_m;
      img.addEventListener('load', function once() {
        img.classList.add('loaded');
        img.removeEventListener('load', once);
        // Upgrade to medium quality after the small one is visible.
        if (img.src !== img.dataset.medium) {
          const upgraded = new Image();
          upgraded.onload = () => { img.src = img.dataset.medium; };
          upgraded.src = img.dataset.medium;
        }
      });
      cell.dataset.path = p.path || '';
      const dateTag = document.createElement('div');
      dateTag.className = 'date-tag';
      dateTag.textContent = (p.datetime || '').slice(0, 10);
      // Mark cells so lightbox / handlers know if this photo is editable.
      cell.dataset.editable = p.editable ? '1' : '0';
      cell.append(img, dateTag);
      container.append(cell);
      cells.push({ p, ratio: 4 / 3, el: cell, img });
    });

    function reflow() {
      let i = 0;
      while (i < cells.length) {
        let j = i;
        let rowRatio = 0;
        while (j < cells.length) {
          rowRatio += cells[j].ratio;
          const heightAt = (width - ROW_GAP * (j - i)) / rowRatio;
          if (heightAt <= TARGET_ROW_HEIGHT) break;
          j++;
        }
        if (j === cells.length) j--;
        const usedRatio = cells.slice(i, j + 1).reduce((s, c) => s + c.ratio, 0);
        const totalGap = ROW_GAP * (j - i);
        const isLastIncomplete = j === cells.length - 1 && usedRatio < width / TARGET_ROW_HEIGHT - 0.3;
        let h = isLastIncomplete ? TARGET_ROW_HEIGHT : (width - totalGap) / usedRatio;
        h = Math.min(h, TARGET_ROW_HEIGHT * 1.3);
        for (let k = i; k <= j; k++) {
          const w = isLastIncomplete
            ? h * cells[k].ratio
            : (width - totalGap) * (cells[k].ratio / usedRatio);
          cells[k].el.style.width = `${w}px`;
          cells[k].el.style.height = `${h}px`;
        }
        i = j + 1;
      }
    }

    reflow();
    let pending = cells.length;
    cells.forEach((c) => {
      const done = () => {
        if (c.img.naturalWidth) c.ratio = c.img.naturalWidth / c.img.naturalHeight;
        if (--pending === 0) reflow();
      };
      if (c.img.complete) done();
      else {
        c.img.addEventListener('load', done, { once: true });
        c.img.addEventListener('error', done, { once: true });
      }
    });
  }

  function setupGrids() {
    document.querySelectorAll<HTMLElement>('.justified-grid').forEach((g) => {
      const photos = JSON.parse(g.dataset.photos || '[]');
      layoutGrid(g, photos);
    });
  }

  setupGrids();
  let resizeT: any;
  window.addEventListener('resize', () => {
    clearTimeout(resizeT);
    resizeT = setTimeout(setupGrids, 150);
  });

  // ---- Selection / batch operations ----
  const selected = new Set<string>();   // set of paths
  const batchBar = document.getElementById('batch-bar')!;
  const batchCount = batchBar.querySelector('.count') as HTMLElement;

  function syncBatchBar() {
    batchCount.textContent = `已選 ${selected.size} 張`;
    batchBar.classList.toggle('show', selected.size > 0);
  }

  function setSelected(cell: HTMLElement, on: boolean) {
    const p = cell.dataset.path || '';
    if (!p) return;
    if (on) { selected.add(p); cell.classList.add('selected'); }
    else { selected.delete(p); cell.classList.remove('selected'); }
  }

  let lastClickedCell: HTMLElement | null = null;

  document.querySelector('.timeline-feed')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const cell = target.closest('.justified-cell') as HTMLElement | null;
    if (!cell) return;

    // Cmd/Ctrl-click → toggle single selection (no lightbox)
    if ((e as MouseEvent).metaKey || (e as MouseEvent).ctrlKey) {
      e.preventDefault();
      setSelected(cell, !cell.classList.contains('selected'));
      lastClickedCell = cell;
      syncBatchBar();
      return;
    }
    // Shift-click → range select between lastClickedCell and this one
    if ((e as MouseEvent).shiftKey && lastClickedCell) {
      e.preventDefault();
      const allCells = Array.from(document.querySelectorAll<HTMLElement>('.timeline-feed .justified-cell'));
      const i = allCells.indexOf(lastClickedCell);
      const j = allCells.indexOf(cell);
      const [lo, hi] = i < j ? [i, j] : [j, i];
      for (let k = lo; k <= hi; k++) setSelected(allCells[k], true);
      syncBatchBar();
      return;
    }

    // Regular click — if anything selected, treat as "add to selection".
    // Otherwise open the lightbox.
    if (selected.size > 0) {
      setSelected(cell, !cell.classList.contains('selected'));
      lastClickedCell = cell;
      syncBatchBar();
      return;
    }

    const img = target.closest('img') as HTMLImageElement | null;
    if (!img) return;
    const allImgs = Array.from(
      document.querySelectorAll<HTMLImageElement>('.timeline-feed .justified-cell img')
    );
    const srcs = allImgs.map((el) => el.dataset.large || el.src);
    const cells = allImgs.map((el) => el.closest('.justified-cell') as HTMLElement | null);
    const ids = cells.map((c) => c?.dataset.id || '');
    const editableFlags = cells.map((c) => c?.dataset.editable === '1');
    const index = allImgs.indexOf(img);
    window.dispatchEvent(new CustomEvent('lightbox:open', {
      detail: { srcs, ids, editable: editableFlags, index: Math.max(0, index) },
    }));
  });

  document.getElementById('batch-clear')?.addEventListener('click', () => {
    document.querySelectorAll('.justified-cell.selected').forEach((c) => c.classList.remove('selected'));
    selected.clear();
    syncBatchBar();
  });

  // Inline auth helper (same as the detail page).
  const TOKEN_KEY = 'photo-admin-token';
  async function authedFetch(url: string, init: RequestInit = {}): Promise<Response> {
    async function go(token: string) {
      const headers = new Headers(init.headers || {});
      if (token) headers.set('Authorization', `Bearer ${token}`);
      return fetch(url, { ...init, headers });
    }
    let res = await go(localStorage.getItem(TOKEN_KEY) || '');
    if (res.status !== 401) return res;
    const entered = await (window as any).promptPassword?.('需要管理員密碼才能編輯');
    if (!entered) return res;
    localStorage.setItem(TOKEN_KEY, entered);
    res = await go(entered);
    if (res.status === 401) {
      localStorage.removeItem(TOKEN_KEY);
      throw new Error('密碼錯誤');
    }
    return res;
  }

  document.getElementById('batch-favorite')?.addEventListener('click', async () => {
    if (selected.size === 0) return;
    try {
      const res = await authedFetch('/api/metadata', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paths: [...selected], favorite: true }),
      });
      const data = await res.json();
      if (!data.ok) throw new Error(data.error || 'batch failed');
      window.dispatchEvent(new CustomEvent('toast:show', {
        detail: { type: 'success', message: `⭐ ${data.count} 張已加入收藏` },
      }));
      document.querySelectorAll('.justified-cell.selected').forEach((c) => c.classList.remove('selected'));
      selected.clear();
      syncBatchBar();
    } catch (err: any) {
      window.dispatchEvent(new CustomEvent('toast:show', {
        detail: { type: 'error', message: `失敗:${err.message || err}` },
      }));
    }
  });

  // ---- Active rail highlight via IntersectionObserver ----
  const railItems = document.querySelectorAll<HTMLAnchorElement>('.rail-item');
  const sections = document.querySelectorAll<HTMLElement>('.country-section');
  const feed = document.querySelector('.timeline-feed') as HTMLElement;
  if (feed && sections.length) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((ent) => {
        if (ent.isIntersecting) {
          const country = ent.target.getAttribute('data-country');
          railItems.forEach((r) => r.classList.toggle('active', r.dataset.country === country));
        }
      });
    }, { root: feed, threshold: 0.05, rootMargin: '-15% 0px -75% 0px' });
    sections.forEach((s) => io.observe(s));
  }
</script>
