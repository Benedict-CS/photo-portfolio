---
export const prerender = false;
import Layout from '~/layouts/Layout.astro';
import { getPhotos, type PhotoView } from '~/lib/photos';

const { id } = Astro.params;
const photos = await getPhotos();
const sorted = [...photos].sort((a, b) => (a.datetime || '').localeCompare(b.datetime || ''));
const idx = sorted.findIndex((p) => p.id === id);
if (idx === -1) {
  return new Response('Not Found', { status: 404 });
}
const photo: PhotoView = sorted[idx];
const prev: PhotoView | null = idx > 0 ? sorted[idx - 1] : null;
const next: PhotoView | null = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const position = { index: idx + 1, total: sorted.length };
// Date only — time-of-day is misleading without a timezone, and the user prefers a clean date.
const prettyDate = photo.datetime ? photo.datetime.slice(0, 10) : '';

// EXIF-supplied values are authoritative — no editing UI for those.
const exifHasLocation = photo.lat !== null && !photo.manualLocation;
const exifHasDate = !!photo.datetime && !photo.manualDatetime;
const locationEditable = !exifHasLocation;
const dateEditable = !exifHasDate;
const anythingEditable = locationEditable || dateEditable;

// Button label adapts to what's actually editable.
const editLabel = locationEditable && dateEditable
  ? (photo.lat ? 'Edit location / date' : 'Set location / date')
  : locationEditable
    ? (photo.lat ? 'Edit location' : 'Set location')
    : 'Edit date';

function flag(code: string) {
  if (!code || code.length !== 2) return '📍';
  return String.fromCodePoint(
    ...[...code.toLowerCase()].map((c) => 0x1f1e6 + (c.charCodeAt(0) - 97))
  );
}
---
<Layout
  title={`${photo.country || 'Photo'} · ${prettyDate || ''} · Photo Portfolio`}
  description={photo.description || `${photo.country || ''} ${prettyDate || ''} · ${photo.album || ''}`.trim()}
  ogImage={photo.thumbs.l}
  ogType="article"
  preloadImage={photo.thumbs.l}
  needsLeaflet={true}
>
  <div class="detail-page">
    <a class="back map-link" href="/">← Map</a>
    <button
      id="back-btn"
      class="back close-x"
      type="button"
      title="Back (Esc)"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" style="pointer-events:none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    {prev && (
      <a class="page-nav prev" href={`/photos/${prev.id}`} data-key="prev" title="Previous (←)" rel="prev">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><polyline points="15 18 9 12 15 6"/></svg>
      </a>
    )}
    {next && (
      <a class="page-nav next" href={`/photos/${next.id}`} data-key="next" title="Next (→)" rel="next">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    )}

    <div class="stage">
      <img
        class="hero"
        src={photo.thumbs.l}
        data-original={photo.originalUrl}
        alt={photo.description || `${photo.country || 'Photo'}${prettyDate ? ` · ${prettyDate}` : ''}`}
        id="hero"
        decoding="async"
        fetchpriority="high"
        transition:name="detail-hero"
        transition:animate="fade"
      />
    </div>

    <div id="loc-modal" class="loc-modal" hidden>
      <div class="loc-modal-inner">
        <header>
          <span>Edit location + date</span>
          <button id="loc-close" type="button" aria-label="Close">×</button>
        </header>
        <div class="loc-date-row">
          <label for="loc-date">📅 Date</label>
          <input type="date" id="loc-date" />
          <button id="loc-date-clear" type="button" class="link-btn" title="Clear manual date (revert to EXIF)">Clear</button>
        </div>
        <div id="loc-map"></div>
        <footer class="loc-footer">
          <div class="loc-status" id="loc-status">No location chosen</div>
          <div class="loc-actions">
            <button id="loc-remove" type="button" class="btn-danger" hidden>Remove manual location</button>
            <button id="loc-cancel" type="button" class="btn-secondary">Cancel</button>
            <button id="loc-save" type="button" class="btn-primary" disabled>Save</button>
          </div>
        </footer>
      </div>
    </div>

    <div class="info-bar">
      <div class="left">
        <span class="flag">{flag(photo.countryCode)}</span>
        <span>{photo.country || '—'}</span>
        <span class="dot">·</span>
        <span>{prettyDate || 'Date unknown'}</span>
        {photo.camera && (
          <>
            <span class="dot">·</span>
            <span class="camera">📷 {photo.camera}</span>
          </>
        )}
      </div>
      <div class="right">
        {/* Group 1 — user reaction (visible to everyone) */}
        <div class="action-group">
          <button
            id="favorite-btn"
            class={`fav-btn ${photo.favorite ? 'on' : ''}`}
            type="button"
            title="Add to favorites (click again to remove)"
            data-fav={photo.favorite ? '1' : '0'}
          >
            {photo.favorite ? '⭐' : '☆'}
          </button>
        </div>

        {/* Group 2 — curator-only edits (hidden by default via .edit-only) */}
        {(anythingEditable || photo.manualLocation) && (
          <div class="action-group edit-only">
            {anythingEditable && (
              <button id="set-location" class="loc-btn" type="button" title={editLabel}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                <span>{editLabel}</span>
              </button>
            )}
            {photo.manualLocation && (
              <button id="revert-location" class="loc-btn revert" type="button" title="Send back (remove manual location)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                <span>Send back</span>
              </button>
            )}
            <button id="delete-photo" class="loc-btn danger" type="button" title="Permanently delete this photo from Nextcloud">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
              <span>Delete</span>
            </button>
          </div>
        )}

        {/* Group 3 — position read-out */}
        <span class="position">{position.index} / {position.total}</span>

        {/* Group 4 — share / export (visible to everyone) */}
        <div class="action-group">
          <button id="copy-link" class="download-link" type="button" title="Copy link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </button>
          <a href={photo.originalUrl} target="_blank" class="download-link" title="Download original">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .detail-page {
    position: relative;
    height: 100vh;
    background: #0a0a0a;
    color: white;
    display: flex;
    flex-direction: column;
  }
  .detail-page .back {
    position: absolute;
    top: 16px;
    z-index: 10;
    color: rgba(255,255,255,0.85);
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(6px);
    cursor: pointer;
    border: none;
    transition: background 0.15s, transform 0.15s;
  }
  .detail-page .back:hover { background: rgba(0,0,0,0.8); text-decoration: none; }

  /* Left: "Back to map" pill link */
  .detail-page .back.map-link {
    left: 18px;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 13px;
  }

  /* Right: circular X close button (returns to previous page) */
  .detail-page .back.close-x {
    right: 18px;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .detail-page .back.close-x:hover { transform: scale(1.08); }

  .detail-page .page-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: rgba(0,0,0,0.45);
    color: white;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    transition: background 0.15s, transform 0.15s;
  }
  .detail-page .page-nav.prev { left: 24px; }
  .detail-page .page-nav.next { right: 24px; }
  .detail-page .page-nav:hover {
    background: rgba(0,0,0,0.8);
    transform: translateY(-50%) scale(1.08);
    text-decoration: none;
  }
  .detail-page .page-nav:active { transform: translateY(-50%) scale(0.96); }

  /* First-paint nudge — the arrows pulse outward twice so the user
     notices they can navigate left/right. Removed by JS once they
     interact (click, keypress, hover) so it doesn't keep distracting. */
  @keyframes nav-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.0); }
    50%      { box-shadow: 0 0 0 10px rgba(255,255,255,0.18); }
  }
  .detail-page .page-nav.hint {
    animation: nav-pulse 1.4s ease-in-out 2;
  }

  .detail-page .stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 90px 30px;
    min-height: 0;
  }
  .detail-page .hero {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    cursor: zoom-in;
    border-radius: 4px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.6);
  }

  .detail-page .info-bar {
    padding: 12px 28px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: rgba(255,255,255,0.85);
    font-size: 13px;
    gap: 16px;
    flex-wrap: wrap;
  }
  .detail-page .info-bar .left,
  .detail-page .info-bar .right {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  /* Action grouping on the right side: each group is a tight cluster of
     chips, separated from the next group by a thin vertical divider.
     Visually parses as "react | edit | position | share". */
  .detail-page .info-bar .right .action-group {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .detail-page .info-bar .right > .action-group + .action-group,
  .detail-page .info-bar .right > .action-group + .position,
  .detail-page .info-bar .right > .position + .action-group {
    margin-left: 6px;
    padding-left: 12px;
    border-left: 1px solid rgba(255, 255, 255, 0.18);
  }
  .detail-page .info-bar .flag { font-size: 18px; line-height: 1; }
  .detail-page .info-bar .dot { color: rgba(255,255,255,0.4); }
  .detail-page .info-bar .album-pill {
    background: rgba(255,255,255,0.12);
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 12px;
  }
  .detail-page .info-bar .position {
    color: rgba(255,255,255,0.55);
    font-variant-numeric: tabular-nums;
  }
  .detail-page .download-link {
    color: rgba(255,255,255,0.85);
    background: rgba(255,255,255,0.1);
    padding: 6px 8px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
  }
  .detail-page .download-link:hover {
    background: rgba(255,255,255,0.2);
    text-decoration: none;
  }
  .detail-page .loc-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.9);
    border: none;
    padding: 6px 10px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
    font-family: inherit;
  }
  .detail-page .loc-btn:hover { background: rgba(255,255,255,0.2); }
  .detail-page .fav-btn {
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.85);
    border: none;
    padding: 6px 10px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 16px;
    font-family: inherit;
    transition: transform 0.18s, background 0.18s;
    position: relative;
  }
  .detail-page .fav-btn:hover { background: rgba(255,255,255,0.22); transform: scale(1.1); }
  .detail-page .fav-btn.on { color: #ffcd3a; background: rgba(255, 205, 58, 0.18); }

  /* ⭐ click feedback: a quick bounce on the star, plus three sparkle
     particles fanning out. The 'bursting' class is added briefly via JS
     when the user activates favourite — removed after the animation
     completes so it can re-fire on the next click. */
  @keyframes fav-bounce {
    0%   { transform: scale(1); }
    30%  { transform: scale(1.45); }
    55%  { transform: scale(0.92); }
    100% { transform: scale(1.1); }
  }
  .detail-page .fav-btn.bursting { animation: fav-bounce 0.4s var(--ease-out); }

  .detail-page .fav-btn .sparkle {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ffcd3a;
    pointer-events: none;
    opacity: 0;
  }
  .detail-page .fav-btn.bursting .sparkle {
    animation: fav-sparkle 0.55s var(--ease-out) forwards;
  }
  .detail-page .fav-btn.bursting .sparkle:nth-child(1) { --tx:  18px; --ty: -22px; animation-delay: 0.04s; }
  .detail-page .fav-btn.bursting .sparkle:nth-child(2) { --tx: -20px; --ty: -14px; animation-delay: 0.08s; }
  .detail-page .fav-btn.bursting .sparkle:nth-child(3) { --tx:   2px; --ty: -28px; animation-delay: 0.00s; }
  @keyframes fav-sparkle {
    0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.6); }
    20%  { opacity: 1; }
    100% { opacity: 0; transform: translate(calc(-50% + var(--tx)), calc(-50% + var(--ty))) scale(0.2); }
  }
  .detail-page .loc-btn.danger {
    background: rgba(180, 50, 50, 0.25);
    color: #ffb0b0;
  }
  .detail-page .loc-btn.danger:hover { background: rgba(180, 50, 50, 0.5); color: white; }

  .loc-modal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }
  /* The class selector above outranks the UA's [hidden] { display: none },
     so we must repeat hidden ourselves with !important. */
  .loc-modal[hidden] { display: none !important; }
  .loc-modal-inner {
    background: white;
    color: var(--text);
    border-radius: 10px;
    overflow: hidden;
    width: min(720px, 92vw);
    height: min(560px, 80vh);
    display: flex;
    flex-direction: column;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
  .loc-modal-inner header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
  }
  .loc-modal-inner header button {
    background: none;
    border: none;
    font-size: 22px;
    cursor: pointer;
    color: var(--muted);
    padding: 0 4px;
  }
  .loc-date-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
  }
  .loc-date-row label { color: var(--muted); }
  .loc-date-row input[type="date"] {
    padding: 4px 8px;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 13px;
    font-family: inherit;
  }
  .loc-date-row .link-btn {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 12px;
    text-decoration: underline;
    padding: 2px 4px;
  }
  .loc-date-row .link-btn:hover { color: var(--text); }

  #loc-map { flex: 1; }
  .loc-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-top: 1px solid var(--border);
    gap: 12px;
  }
  .loc-status {
    font-size: 12px;
    color: var(--muted);
    flex: 1;
    min-width: 0;
  }
  .loc-status.dirty { color: var(--accent); font-weight: 500; }
  .loc-status.saving { color: #b46d00; }
  .loc-status.saved { color: #1a8a3a; }
  .loc-status.error { color: #c93; }
  .loc-actions { display: flex; gap: 8px; flex-shrink: 0; }
  .btn-primary, .btn-secondary {
    padding: 6px 16px;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
    font-family: inherit;
    border: 1px solid transparent;
  }
  .btn-primary {
    background: var(--accent);
    color: white;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .btn-primary:hover:not(:disabled) { background: #024fa1; }
  .btn-primary:disabled { background: #d0d7e0; cursor: not-allowed; }
  .btn-primary.loading::before {
    content: '';
    width: 12px;
    height: 12px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .btn-secondary {
    background: white;
    color: var(--text);
    border-color: var(--border);
  }
  .btn-secondary:hover { background: #f3f4f6; }
  .btn-danger {
    background: white;
    color: #c93636;
    border-color: #f0c0c0;
  }
  .btn-danger:hover { background: #fdf0f0; border-color: #d97070; }

  @media (max-width: 720px) {
    .detail-page .stage { padding: 50px 14px 12px; }
    .detail-page .page-nav { width: 40px; height: 40px; }
    .detail-page .page-nav.prev { left: 6px; }
    .detail-page .page-nav.next { right: 6px; }
    .detail-page .back.map-link { top: 10px; left: 10px; padding: 6px 10px; font-size: 12px; }
    .detail-page .back.close-x { top: 10px; right: 10px; width: 36px; height: 36px; }

    /* Info bar: stack into two rows; right side becomes a horizontal scroll-strip. */
    .detail-page .info-bar {
      padding: 8px 12px 14px;
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
      font-size: 12px;
    }
    .detail-page .info-bar .left {
      flex-wrap: wrap;
      gap: 6px;
    }
    .detail-page .info-bar .right {
      gap: 6px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 2px;
    }
    .detail-page .info-bar .right::-webkit-scrollbar { display: none; }
    /* Bigger touch targets for the action chips. */
    .detail-page .loc-btn,
    .detail-page .fav-btn,
    .detail-page .download-link {
      min-height: 36px;
      padding: 8px 10px;
      flex-shrink: 0;
    }
    .detail-page .loc-btn span { white-space: nowrap; }
    .detail-page .info-bar .position { font-size: 11px; }

    /* Edit-location modal becomes a near-fullscreen sheet on mobile. */
    .loc-modal-inner {
      width: 100vw;
      height: 100vh;
      max-width: 100vw;
      max-height: 100vh;
      border-radius: 0;
    }
    .loc-footer { flex-wrap: wrap; gap: 8px; }
    .loc-actions { width: 100%; justify-content: flex-end; }
    .btn-primary, .btn-secondary, .btn-danger {
      min-height: 40px;
      font-size: 14px;
    }
    .loc-date-row { flex-wrap: wrap; }
  }
</style>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
<script define:vars={{
  prevHref: prev?.id ? `/photos/${prev.id}` : null,
  nextHref: next?.id ? `/photos/${next.id}` : null,
  originalUrl: photo.originalUrl,
  photoPath: photo.path,
  initialLat: photo.lat || null,
  initialLon: photo.lon || null,
  manualLocation: photo.manualLocation,
  initialDate: photo.datetime ? photo.datetime.slice(0, 10) : '',
  exifProvidedLocation: exifHasLocation,
  exifProvidedDate: exifHasDate,
  anythingEditable,
}}>
  // This define:vars re-runs on every ClientRouter visit, so window-level
  // listeners accumulate unless we tear them down before the next swap.
  const __pageAbort = new AbortController();
  const __signal = __pageAbort.signal;
  document.addEventListener('astro:before-swap', () => __pageAbort.abort(), { once: true, signal: __signal });

  // "Where did the user come from before entering this detail flow?"
  // history.back() is wrong: if they hit ← / → a few times, back() just
  // walks through previous photos instead of returning to the list page.
  // We pin the entry URL in sessionStorage on first hit and reuse it.
  const PARENT_KEY = 'detail-parent-url';
  function isDetailUrl(url) {
    try { return new URL(url).pathname.startsWith('/photos/'); }
    catch { return false; }
  }
  function pinParentIfNew() {
    const stored = sessionStorage.getItem(PARENT_KEY);
    if (stored) return;
    // Prefer document.referrer when it's same-origin AND not another detail page.
    const ref = document.referrer;
    if (ref && new URL(ref).origin === window.location.origin && !isDetailUrl(ref)) {
      sessionStorage.setItem(PARENT_KEY, ref);
    } else {
      // No useful referrer (direct link, external referrer, deep refresh) → fall
      // back to /timeline because it's the most likely entry point.
      sessionStorage.setItem(PARENT_KEY, '/timeline');
    }
  }
  pinParentIfNew();
  function goParent() {
    const parent = sessionStorage.getItem(PARENT_KEY) || '/';
    // Clear so the next non-detail navigation starts fresh.
    sessionStorage.removeItem(PARENT_KEY);
    window.location.href = parent;
  }
  document.getElementById('back-btn')?.addEventListener('click', goParent);

  document.addEventListener('keydown', (e) => {
    if (document.getElementById('loc-modal')?.hidden === false) return;
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowLeft' && prevHref) window.location.href = prevHref;
    else if (e.key === 'ArrowRight' && nextHref) window.location.href = nextHref;
    else if (e.key === 'Escape') goParent();
  }, { signal: __signal });

  // First-paint nudge: pulse the ← → buttons twice so the user notices
  // they can navigate. Drops the class on first interaction so it
  // doesn't loop visibly. Only fires for users who haven't seen the
  // hint before (localStorage flag).
  const HINT_KEY = 'detail-arrow-hint-seen';
  if (!localStorage.getItem(HINT_KEY)) {
    const arrows = document.querySelectorAll('.detail-page .page-nav');
    arrows.forEach((a) => a.classList.add('hint'));
    const drop = () => {
      arrows.forEach((a) => a.classList.remove('hint'));
      localStorage.setItem(HINT_KEY, '1');
      window.removeEventListener('keydown', drop);
      arrows.forEach((a) => a.removeEventListener('mouseenter', drop));
    };
    setTimeout(drop, 3200); // pulse animation runs 2 × 1.4s
    window.addEventListener('keydown', drop, { once: true, signal: __signal });
    arrows.forEach((a) => a.addEventListener('mouseenter', drop, { once: true, signal: __signal }));
  }

  document.getElementById('hero')?.addEventListener('click', () => {
    window.open(originalUrl, '_blank');
  });

  // Note: back-btn click is wired via inline onclick (simpler, no race
  // with other JS). Esc key handled in the keydown listener above.

  // ---- Location + date editor modal ----
  const modal = document.getElementById('loc-modal');
  const status = document.getElementById('loc-status');
  const saveBtn = document.getElementById('loc-save');
  const cancelBtn = document.getElementById('loc-cancel');
  const removeBtn = document.getElementById('loc-remove');
  const dateInput = document.getElementById('loc-date');
  const dateClear = document.getElementById('loc-date-clear');

  let map = null;
  let marker = null;
  let pendingLatLng = null;
  let savedLatLng = initialLat !== null && initialLon !== null
    ? { lat: initialLat, lng: initialLon }
    : null;
  let savedDate = initialDate || '';
  let pendingDate = savedDate;

  function isLocDirty() {
    if (exifProvidedLocation) return false;  // EXIF locked, never dirty
    if (!pendingLatLng) return false;
    if (!savedLatLng) return true;
    return Math.abs(pendingLatLng.lat - savedLatLng.lat) > 1e-6
        || Math.abs(pendingLatLng.lng - savedLatLng.lng) > 1e-6;
  }
  function isDateDirty() {
    if (exifProvidedDate) return false;       // EXIF locked, never dirty
    return pendingDate !== savedDate;
  }
  function isDirty() { return isLocDirty() || isDateDirty(); }

  function updateStatus() {
    saveBtn.disabled = !isDirty();
    if (removeBtn) removeBtn.hidden = !manualLocation || !savedLatLng;
    let parts = [];
    if (savedLatLng) parts.push(`Location: ${savedLatLng.lat.toFixed(4)}, ${savedLatLng.lng.toFixed(4)}`);
    else parts.push('Location: none');
    if (savedDate) parts.push(`Date: ${savedDate}`);
    if (isDirty()) {
      status.className = 'loc-status dirty';
      const changes = [];
      if (isLocDirty()) changes.push(`Location → ${pendingLatLng.lat.toFixed(4)}, ${pendingLatLng.lng.toFixed(4)}`);
      if (isDateDirty()) changes.push(`Date → ${pendingDate || '(cleared)'}`);
      status.textContent = `Unsaved: ${changes.join(' · ')}`;
    } else {
      status.className = 'loc-status';
      status.textContent = parts.join(' · ');
    }
  }

  function setPin(latLng) {
    pendingLatLng = { lat: latLng.lat, lng: latLng.lng };
    if (marker) {
      marker.setLatLng(latLng);
    } else {
      marker = L.marker(latLng, { draggable: true }).addTo(map);
      marker.on('dragend', () => {
        pendingLatLng = { lat: marker.getLatLng().lat, lng: marker.getLatLng().lng };
        updateStatus();
      });
    }
    updateStatus();
  }

  function openLocModal() {
    modal.hidden = false;
    // EXIF is authoritative: hide whatever EXIF already provided so the user
    // can ONLY fill in what's missing.
    const dateRow = document.querySelector('.loc-date-row');
    const mapEl = document.getElementById('loc-map');
    if (dateRow) dateRow.style.display = exifProvidedDate ? 'none' : '';
    if (mapEl) mapEl.style.display = exifProvidedLocation ? 'none' : '';
    if (!exifProvidedLocation && !map) {
      map = L.map('loc-map', { worldCopyJump: true });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        maxZoom: 19, subdomains: 'abcd', attribution: '&copy; OpenStreetMap &copy; CARTO',
      }).addTo(map);
      const startLat = initialLat ?? 23.5;
      const startLon = initialLon ?? 121;
      map.setView([startLat, startLon], initialLat ? 11 : 4);
      if (initialLat) setPin({ lat: startLat, lng: startLon });
      map.on('click', (e) => setPin(e.latlng));
    }
    dateInput.value = pendingDate;
    updateStatus();
    if (map) setTimeout(() => map.invalidateSize(), 50);
  }

  function closeLocModal() {
    if (isDirty() && !confirm('You have unsaved changes. Discard and close?')) return;
    // Reset pending state to last-saved so reopening doesn't keep stale data
    pendingLatLng = savedLatLng ? { ...savedLatLng } : null;
    pendingDate = savedDate;
    if (marker && savedLatLng) marker.setLatLng(savedLatLng);
    if (dateInput) dateInput.value = pendingDate;
    modal.hidden = true;
  }

  // Inline mini-auth helper — sends saved token; on 401 prompts once.
  const TOKEN_KEY = 'photo-admin-token';
  async function authedFetch(url, init = {}) {
    async function go(token) {
      const headers = new Headers(init.headers || {});
      if (token) headers.set('Authorization', `Bearer ${token}`);
      return fetch(url, { ...init, headers });
    }
    let res = await go(localStorage.getItem(TOKEN_KEY) || '');
    if (res.status !== 401) return res;
    const entered = await (window).promptPassword?.('Admin password required');
    if (!entered) return res;
    localStorage.setItem(TOKEN_KEY, entered);
    res = await go(entered);
    if (res.status === 401) {
      localStorage.removeItem(TOKEN_KEY);
      throw new Error('Wrong password');
    }
    return res;
  }

  async function postMetadata(body) {
    const res = await authedFetch('/api/metadata', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ path: photoPath, ...body }),
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error || 'save failed');
    return data.photo;
  }

  function toast(type, message) {
    window.dispatchEvent(new CustomEvent('toast:show', { detail: { type, message } }));
  }

  async function doSave() {
    saveBtn.disabled = true;
    saveBtn.classList.add('loading');
    status.className = 'loc-status saving';
    status.textContent = 'Saving…';
    try {
      const body = {};
      if (isLocDirty() && pendingLatLng) {
        body.lat = pendingLatLng.lat;
        body.lon = pendingLatLng.lng;
      }
      if (isDateDirty()) body.datetime = pendingDate || null;
      const updated = await postMetadata(body);
      if (updated) {
        if (updated.lat !== null && updated.lon !== null) {
          savedLatLng = { lat: updated.lat, lng: updated.lon };
          if (marker) marker.setLatLng([updated.lat, updated.lon]);
        }
        savedDate = updated.datetime ? updated.datetime.slice(0, 10) : '';
        pendingDate = savedDate;
        if (dateInput) dateInput.value = pendingDate;
      }
      updateStatus();
      saveBtn.classList.remove('loading');
      // Auto-close + toast so the photo is visible and feedback is clear.
      modal.hidden = true;
      const country = updated?.country || '';
      toast('success', country ? `Saved to ${country}` : 'Saved');
    } catch (err) {
      status.className = 'loc-status error';
      status.textContent = `⚠ Failed: ${err.message || err}`;
      saveBtn.disabled = false;
      saveBtn.classList.remove('loading');
      toast('error', `Save failed: ${err.message || err}`);
    }
  }

  async function doRemove() {
    if (!confirm('Remove the manual location? The photo will go back to Unlocated.')) return;
    try {
      await postMetadata({ lat: null, lon: null });
      toast('success', 'Manual location removed');
      // Brief delay so the toast is seen before navigation.
      setTimeout(() => { window.location.href = '/timeline'; }, 600);
    } catch (err) {
      toast('error', `Remove failed: ${err.message || err}`);
    }
  }

  dateInput.addEventListener('input', () => {
    pendingDate = dateInput.value;
    updateStatus();
  });
  dateClear.addEventListener('click', () => {
    pendingDate = '';
    dateInput.value = '';
    updateStatus();
  });

  document.getElementById('set-location')?.addEventListener('click', openLocModal);
  document.getElementById('loc-close')?.addEventListener('click', closeLocModal);
  cancelBtn?.addEventListener('click', closeLocModal);
  saveBtn?.addEventListener('click', doSave);
  removeBtn?.addEventListener('click', doRemove);
  document.getElementById('revert-location')?.addEventListener('click', doRemove);

  document.getElementById('favorite-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget;
    // Guard against rapid double-clicks that would race two POSTs.
    if (btn.disabled) return;
    const now = btn.dataset.fav === '1';
    const next = !now;
    btn.disabled = true;
    btn.dataset.fav = next ? '1' : '0';
    btn.classList.toggle('on', next);
    btn.textContent = next ? '⭐' : '☆';
    // Only burst when activating (going OFF -> ON). Re-injects three
    // sparkle nodes each time so the CSS animation re-fires cleanly.
    if (next) {
      btn.querySelectorAll('.sparkle').forEach((s) => s.remove());
      for (let i = 0; i < 3; i++) {
        const s = document.createElement('span');
        s.className = 'sparkle';
        btn.appendChild(s);
      }
      btn.classList.add('bursting');
      setTimeout(() => btn.classList.remove('bursting'), 600);
    }
    try {
      await postMetadata({ favorite: next });
      toast('success', next ? '⭐ Added to favorites' : 'Removed from favorites');
    } catch (err) {
      // Rollback on error
      btn.dataset.fav = now ? '1' : '0';
      btn.classList.toggle('on', now);
      btn.textContent = now ? '⭐' : '☆';
      toast('error', `Failed: ${err.message || err}`);
    } finally {
      btn.disabled = false;
    }
  });

  document.getElementById('copy-link')?.addEventListener('click', async () => {
    const url = window.location.href.replace(/\?pin=1$/, '');
    try {
      await navigator.clipboard.writeText(url);
      toast('success', '✓ Link copied');
    } catch {
      // Fallback for non-https contexts.
      const ta = document.createElement('textarea');
      ta.value = url;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      toast('success', '✓ Link copied');
    }
  });

  document.getElementById('delete-photo')?.addEventListener('click', async () => {
    if (!confirm("Delete this photo permanently?\n\nIt will be removed from Nextcloud and can't be undone.")) return;
    try {
      const res = await authedFetch('/api/metadata', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ path: photoPath }),
      });
      const data = await res.json();
      if (!data.ok) throw new Error(data.error || 'delete failed');
      toast('success', 'Deleted');
      setTimeout(() => { window.location.href = '/timeline'; }, 500);
    } catch (err) {
      toast('error', `Delete failed: ${err.message || err}`);
    }
  });
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeLocModal(); });

  // Only auto-open the modal when the user EXPLICITLY came here to edit
  // (?pin=1 query param). Otherwise let them view the photo in peace and
  // click the edit button themselves when they're ready.
  if (anythingEditable) {
    const url = new URL(window.location.href);
    if (url.searchParams.get('pin') === '1') {
      setTimeout(openLocModal, 80);
    }
  }
</script>
