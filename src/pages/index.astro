---
export const prerender = false;
import Layout from '~/layouts/Layout.astro';
import TopBar from '~/components/TopBar.astro';
import PreviewPanel from '~/components/PreviewPanel.astro';
import { getPhotos } from '~/lib/photos';

const allPhotos = await getPhotos();
// Map only displays photos with coordinates; no-GPS photos live in the
// Timeline "📍 Unlocated" bucket until the user pins a location for them.
const photos = allPhotos.filter((p) => p.lat !== null && p.lon !== null);
---
<Layout title="📸 Photo Portfolio · Map" needsLeaflet={true}>
  <div class="app-shell">
    <TopBar photos={allPhotos} active="map" />
    <main id="main">
      <div id="map"></div>
      <div id="map-toolbar">
        <button id="mode-markers" class="map-mode-btn active" title="Markers">
          <span class="emoji">📍</span><span class="label">Markers</span>
        </button>
        <button id="mode-routes" class="map-mode-btn" title="Trip routes (same country + ≤7 day gap)">
          <span class="emoji">⚡</span><span class="label">Trips</span>
        </button>
        <button id="ts-toggle" class="map-mode-btn" type="button" title="Time slider">
          <span class="emoji">🕐</span><span class="label">Time</span>
        </button>
      </div>
      <div id="time-slider" hidden>
        <div class="ts-labels">
          <span id="ts-from">—</span>
          <span id="ts-active">All time</span>
          <span id="ts-to">—</span>
        </div>
        <input id="ts-range" type="range" min="0" max="100" value="100" step="1" />
      </div>
      <PreviewPanel />
    </main>
  </div>
</Layout>

<style is:global>
  #map-toolbar {
    position: absolute;
    bottom: 24px;
    left: 14px;
    z-index: 1000;
    background: white;
    border-radius: 999px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.16);
    display: flex;
    padding: 4px;
    gap: 2px;
  }
  .map-mode-btn {
    background: none;
    border: none;
    cursor: pointer;
    /* WCAG SC 2.5.5: 44×44 minimum touch target. Buttons grow horizontally
       to accommodate their text labels on desktop. */
    min-width: 44px;
    height: 44px;
    padding: 0 14px;
    border-radius: 999px;
    font-size: 13px;
    color: var(--text);
    transition: background 0.15s, color 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: inherit;
  }
  .map-mode-btn .emoji { font-size: 16px; line-height: 1; }
  .map-mode-btn .label { font-weight: 500; }
  .map-mode-btn:hover { background: #f3f4f6; }
  .map-mode-btn.active { background: var(--accent); color: white; }

  /* Narrow viewports: collapse to emoji-only so the pill fits any phone. */
  @media (max-width: 540px) {
    .map-mode-btn { padding: 0; width: 44px; }
    .map-mode-btn .label { display: none; }
  }

  /* Time slider lives next to the markers / routes mode buttons (bottom-left). */
  #time-slider {
    position: absolute;
    bottom: 72px;            /* sit above the toolbar pill */
    left: 14px;
    z-index: 1000;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(6px);
    border-radius: 10px;
    padding: 10px 14px;
    box-shadow: 0 4px 18px rgba(0,0,0,0.16);
    width: min(320px, calc(100vw - 90px));
    box-sizing: border-box;
    animation: ts-slide-in 0.18s ease-out;
  }
  #time-slider[hidden] { display: none; }
  @keyframes ts-slide-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  #time-slider .ts-labels {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--muted);
    margin-bottom: 6px;
  }
  #time-slider .ts-active {
    font-weight: 600;
    color: var(--accent);
  }
  #time-slider input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
  }

  /* Trip route polyline */
  .route-line {
    stroke: var(--accent);
    stroke-width: 2.5;
    stroke-dasharray: 4 6;
    fill: none;
    opacity: 0.7;
  }
</style>

<script src="/lib/leaflet/leaflet.js" is:inline></script>
<script src="/lib/leaflet/leaflet.markercluster.js" is:inline></script>

<script define:vars={{ photos }}>
  // After three failed attempts at fixing this, here's the design that
  // actually survives ClientRouter:
  //
  // 1. A SINGLE persistent astro:page-load listener (gated by a window
  //    flag) that ALWAYS runs on every navigation. It doesn't depend on
  //    define:vars re-executing — even if Astro chose not to re-run this
  //    block, the listener fires and re-mounts the map.
  //
  // 2. The init function is published on `window.__currentMapInit`. Every
  //    fresh define:vars execution overwrites it with a NEW closure that
  //    captures the latest `photos` array. The listener always calls the
  //    most recent version.
  //
  // 3. The old Leaflet instance is disposed at the top of init (not on
  //    before-swap) so the operation is atomic regardless of which event
  //    triggered it.

  function minZoomForViewport() {
    return Math.max(2, Math.ceil(Math.log2(window.innerWidth / 256)));
  }

  function initLeafletMap() {
    const mapDiv = document.getElementById('map');
    if (!mapDiv) return; // Not on / — listener fires page-wide.

    // After a ClientRouter body swap, the new <script src="leaflet.js"
    // is:inline> tags are async-fetched in the background. This inline
    // define:vars script runs synchronously, so on the second visit we
    // can race ahead of both leaflet.js and leaflet.markercluster.js.
    // Poll on a short timer until both globals are ready, then retry.
    if (!window.L || typeof window.L.markerClusterGroup !== 'function') {
      setTimeout(initLeafletMap, 50);
      return;
    }

    // Double-init guard: both the astro:page-load listener and any
    // synchronous bootstrap can fire init on a fresh navigation. If a
    // previous call already mounted on THIS same DOM node, bail —
    // otherwise Leaflet throws "Map container is already initialized".
    if (window.__leafletMap && window.__leafletMap._container === mapDiv) {
      return;
    }

    // Dispose any prior Leaflet instance before we mount on the (new) div.
    if (window.__leafletMap) {
      try { window.__leafletMap.remove(); } catch {}
      window.__leafletMap = null;
    }

  const L = window.L;
  const map = L.map('map', {
    zoomControl: true,
    minZoom: minZoomForViewport(),
    // Vertical: hard wall at ±85° so no grey above/below the world.
    // Horizontal: practically unlimited — combined with the dynamic marker
    // duplication below, you can pan east/west forever and photos keep
    // appearing in each world copy.
    maxBounds: [[-85, -10000], [85, 10000]],
    maxBoundsViscosity: 1.0,
  });

  // Recompute on window resize — but never force-snap the current view, just
  // tighten the floor so subsequent zoom-outs are limited. The listener is
  // intentionally not cleaned up between mounts (cheap one-line callback;
  // the previous map.setMinZoom call is a harmless no-op on a disposed map).
  window.addEventListener('resize', () => {
    const z = minZoomForViewport();
    try { if (map.getMinZoom() !== z) map.setMinZoom(z); } catch {}
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    maxZoom: 19,
    subdomains: 'abcd',
    attribution: '&copy; OpenStreetMap &copy; CARTO',
    noWrap: false,
  }).addTo(map);

  // (Removed dynamic minZoom: it was snapping the view back during interaction.
  //  Fixed minZoom of 2 is set in the map options above; small grey peeks at
  //  the very edge are acceptable.)

  // Custom photo-thumbnail markers (circular)
  function photoMarkerIcon(photo) {
    return L.divIcon({
      html: `<div class="photo-marker"><img loading="lazy" src="${photo.thumbs.s}" alt=""></div>`,
      className: '',
      iconSize: [52, 52],
      iconAnchor: [26, 26],
    });
  }

  // Cluster icon: top photo + count badge
  const cluster = L.markerClusterGroup({
    maxClusterRadius: 60,
    showCoverageOnHover: false,
    spiderfyOnMaxZoom: true,
    disableClusteringAtZoom: 18,
    iconCreateFunction(cl) {
      const count = cl.getChildCount();
      const top = cl.getAllChildMarkers()[0];
      const thumb = top?.options?.photoThumb || '';
      return L.divIcon({
        html: `<div class="photo-cluster">
          <div class="stack"><img src="${thumb}" alt="" loading="lazy" decoding="async"></div>
          <span class="badge">${count}</span>
        </div>`,
        className: '',
        iconSize: [64, 64],
        iconAnchor: [32, 32],
      });
    },
  });
  map.addLayer(cluster);

  // Lazy infinite markers: as the user pans, we add markers in whatever world
  // copies become visible (and keep them there). No upfront cost for distant
  // worlds; no "they vanished" surprise either.
  const populatedWorlds = new Set();
  function makeMarker(p, off) {
    const m = L.marker([p.lat, p.lon + off], {
      icon: photoMarkerIcon(p),
      photoThumb: p.thumbs.s,
      riseOnHover: true,
    });
    m.on('click', (e) => {
      L.DomEvent.stopPropagation(e);
      window.dispatchEvent(new CustomEvent('preview:open', { detail: { photo: p } }));
    });
    return m;
  }
  function populateWorld(worldIndex) {
    if (populatedWorlds.has(worldIndex)) return;
    populatedWorlds.add(worldIndex);
    const off = worldIndex * 360;
    const batch = photos.map((p) => makeMarker(p, off));
    cluster.addLayers(batch);
  }
  function syncVisibleWorlds() {
    const b = map.getBounds();
    // Allow a 1-world buffer on each side so markers appear before they enter view.
    const minW = Math.floor((b.getWest() + 180) / 360) - 1;
    const maxW = Math.floor((b.getEast() + 180) / 360) + 1;
    for (let w = minW; w <= maxW; w++) populateWorld(w);
  }
  populateWorld(0); // original world up-front so initial paint is fast
  map.on('moveend zoomend', syncVisibleWorlds);

  // ----- "Fit all" reset button -----
  const photoBounds = photos.length
    ? L.latLngBounds(photos.map((p) => [p.lat, p.lon]))
    : null;
  if (photoBounds) {
    map.fitBounds(photoBounds, { padding: [80, 80] });
  } else {
    map.setView([25.033, 121.5654], 10);
  }

  const ResetView = L.Control.extend({
    options: { position: 'topright' },
    onAdd() {
      const a = L.DomUtil.create('a', 'leaflet-bar reset-view-btn');
      a.title = 'Show all photos';
      a.href = '#';
      a.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>`;
      L.DomEvent.on(a, 'click', (e) => {
        L.DomEvent.stop(e);
        if (photoBounds) map.flyToBounds(photoBounds, { padding: [80, 80], duration: 0.7 });
      });
      return a;
    },
  });
  new ResetView().addTo(map);

  map.on('click', () => window.dispatchEvent(new Event('preview:close')));
  // Close the preview as soon as the user starts panning / zooming somewhere
  // else — keeping the old photo overlaid while they explore another region
  // is disorienting. dragstart covers mouse + touch; zoomstart covers
  // scroll-wheel + pinch.
  map.on('dragstart zoomstart', () => window.dispatchEvent(new Event('preview:close')));

  // ---- Time slider: only show photos with datetime <= slider value ----
  const datedPhotos = photos.filter((p) => p.datetime);
  const sortedTimes = datedPhotos.map((p) => p.datetime.slice(0, 10)).sort();
  const minDate = sortedTimes[0] || '';
  const maxDate = sortedTimes[sortedTimes.length - 1] || '';
  const tsFrom = document.getElementById('ts-from');
  const tsTo = document.getElementById('ts-to');
  const tsActive = document.getElementById('ts-active');
  const tsRange = document.getElementById('ts-range');
  if (tsFrom) tsFrom.textContent = minDate || '—';
  if (tsTo) tsTo.textContent = maxDate || '—';

  // Slider visibility — collapsed by default, click 🕐 to toggle.
  const tsToggle = document.getElementById('ts-toggle');
  const tsPanel = document.getElementById('time-slider');
  tsToggle?.addEventListener('click', () => {
    if (!tsPanel) return;
    const showing = !tsPanel.hidden;
    tsPanel.hidden = showing;
    tsToggle.classList.toggle('active', !showing);
  });

  let timeFilter = 100; // 0–100, percent of timeline included (from min to that point)
  function dateAtSliderValue(val) {
    if (!sortedTimes.length) return maxDate;
    const idx = Math.floor((val / 100) * (sortedTimes.length - 1));
    return sortedTimes[idx];
  }
  function isPhotoIncludedByTime(p) {
    if (timeFilter >= 100) return true;
    if (!p.datetime) return false;
    return p.datetime.slice(0, 10) <= dateAtSliderValue(timeFilter);
  }
  tsRange?.addEventListener('input', () => {
    timeFilter = parseInt(tsRange.value, 10);
    const cutoff = dateAtSliderValue(timeFilter);
    if (tsActive) tsActive.textContent = timeFilter >= 100 ? 'All time' : `≤ ${cutoff}`;
    rerender();
  });

  // ---- Mode switcher (markers / routes) ----
  let mode = 'markers';
  function setMode(next) {
    mode = next;
    document.querySelectorAll('.map-mode-btn').forEach((b) => b.classList.remove('active'));
    document.getElementById(`mode-${next}`)?.classList.add('active');
    rerender();
  }
  document.getElementById('mode-markers')?.addEventListener('click', () => setMode('markers'));
  document.getElementById('mode-routes')?.addEventListener('click', () => setMode('routes'));

  // ---- Auto-detected trip polylines ----
  // No need for albums. We group photos by:
  //   - same country, AND
  //   - consecutive photos within 7 days of each other.
  // Each resulting group of 2+ photos becomes one polyline.
  const TRIP_GAP_DAYS = 7;
  const ONE_DAY_MS = 86_400_000;
  const PALETTE = ['#0366d6', '#d97706', '#16a34a', '#9333ea', '#dc2626', '#0891b2', '#ca8a04'];

  function colorFor(seed) {
    let h = 0;
    for (let i = 0; i < seed.length; i++) h = (h * 31 + seed.charCodeAt(i)) | 0;
    return PALETTE[Math.abs(h) % PALETTE.length];
  }

  const routeLayer = L.layerGroup();
  function buildRoutes() {
    routeLayer.clearLayers();
    const visible = photos
      .filter(isPhotoIncludedByTime)
      .filter((p) => p.datetime && p.country)
      .sort((a, b) => a.datetime.localeCompare(b.datetime));

    let group = [];
    function flush() {
      if (group.length >= 2) {
        const pts = group.map((p) => [p.lat, p.lon]);
        L.polyline(pts, {
          color: colorFor(group[0].country + group[0].datetime.slice(0, 7)),
          weight: 3,
          opacity: 0.75,
          dashArray: '5 8',
        }).addTo(routeLayer);
      }
      group = [];
    }

    for (const p of visible) {
      const prev = group[group.length - 1];
      if (!prev) { group.push(p); continue; }
      const sameCountry = prev.country === p.country;
      const gapDays = (new Date(p.datetime).getTime() - new Date(prev.datetime).getTime()) / ONE_DAY_MS;
      if (sameCountry && gapDays <= TRIP_GAP_DAYS) {
        group.push(p);
      } else {
        flush();
        group.push(p);
      }
    }
    flush();
  }

  // ---- Re-render everything when mode/time changes ----
  function rerender() {
    // Markers layer
    cluster.clearLayers();
    if (mode === 'markers' || mode === 'routes') {
      const visible = photos.filter(isPhotoIncludedByTime);
      // (we don't repopulate distant worlds here — they were added on pan)
      const ms = visible.map((p) => makeMarker(p, 0));
      cluster.addLayers(ms);
      if (!map.hasLayer(cluster)) map.addLayer(cluster);
    } else {
      if (map.hasLayer(cluster)) map.removeLayer(cluster);
    }

    // Routes
    if (mode === 'routes') {
      buildRoutes();
      if (!map.hasLayer(routeLayer)) map.addLayer(routeLayer);
    } else {
      if (map.hasLayer(routeLayer)) map.removeLayer(routeLayer);
    }
  }

    // Park the instance on window so the next visit's init can dispose it.
    window.__leafletMap = map;

    // Belt-and-braces: tell Leaflet to recompute its container size in
    // the next frame, in case CSS hadn't fully applied when we mounted.
    requestAnimationFrame(() => map.invalidateSize());
  } // end initLeafletMap()

  // Publish the freshest closure (which captures THIS page's photos array)
  // so the persistent listener below always calls the latest version.
  window.__currentMapInit = initLeafletMap;

  // Bind the global astro:page-load listener exactly ONCE per session.
  // It survives across navigations because it isn't bound through any
  // AbortController. On every nav that ends on /, it fires and calls
  // whatever window.__currentMapInit currently points at.
  if (!window.__mapListenerBound) {
    window.__mapListenerBound = true;
    document.addEventListener('astro:page-load', () => {
      // RAF defers the mount until the swapped-in DOM has a layout box.
      if (typeof window.__currentMapInit === 'function') {
        requestAnimationFrame(window.__currentMapInit);
      }
    });
  }

  // Initial-load path: astro:page-load might fire BEFORE this define:vars
  // runs (race on first page load), so trigger one synchronous attempt.
  // initLeafletMap is idempotent (disposes any prior instance first).
  requestAnimationFrame(initLeafletMap);
</script>
