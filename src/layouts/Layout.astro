---
import '~/styles/global.css';
import Toast from '~/components/Toast.astro';
import PasswordPrompt from '~/components/PasswordPrompt.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  /** Optional URL to <link rel="preload"> for LCP (typically the hero image). */
  preloadImage?: string;
  /** Extra image URLs to preload — e.g. the first row of timeline thumbs,
   *  where the imgs themselves are created by client JS (so the browser
   *  can't discover them from HTML alone). */
  preloadThumbs?: string[];
  /** Only the map page (and the detail page's edit modal) need Leaflet —
   *  loading its CSS on every page wastes ~10 KB of render-blocking critical
   *  CSS on /timeline, /favorites, /admin, /photos/[id] in the default view. */
  needsLeaflet?: boolean;
}
const {
  title = 'Photo Portfolio',
  description = 'A travel photo portfolio · pins on a world map',
  ogImage = '/icon-512.png',
  ogType = 'website',
  preloadImage,
  preloadThumbs = [],
  needsLeaflet = false,
} = Astro.props;

const siteBase = Astro.site?.toString().replace(/\/$/, '') || '';
const canonical = new URL(Astro.url.pathname, Astro.site || `http://localhost:4321/`).toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteBase}${ogImage}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#0a0a0a" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/icon-192.png" />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
  {preloadImage && (
    <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
  )}
  {preloadThumbs.map((src) => (
    <link rel="preload" as="image" href={src} />
  ))}

  {needsLeaflet && (
    <>
      {/* Warm up CDN connections in parallel with the HTML download. */}
      <link rel="preconnect" href="https://unpkg.com" crossorigin />
      <link rel="dns-prefetch" href="https://basemaps.cartocdn.com" />
    </>
  )}

  <!-- Open Graph (LINE / FB / Slack / Discord) -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Photo Portfolio" />
  <!-- Twitter / X large-image card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  {needsLeaflet && (
    <>
      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
      <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
      <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />
    </>
  )}
</head>
<body>
  <slot />
  <Toast />
  <PasswordPrompt />
  <script>
    // Sync body.logged-in class with the stored admin token, on EVERY page —
    // not just the ones with TopBar. Drives `.edit-only` visibility globally.
    const TOKEN_KEY = 'photo-admin-token';
    function syncAuthClass() {
      const has = !!localStorage.getItem(TOKEN_KEY);
      document.body.classList.toggle('logged-in', has);
      document.body.classList.toggle('logged-out', !has);
    }
    syncAuthClass();
    window.addEventListener('storage', (e) => { if (e.key === TOKEN_KEY) syncAuthClass(); });
    window.addEventListener('auth:changed', syncAuthClass);

    // Register the service worker on supported browsers. Scope: '/' so it
    // covers every route. Failures are silent — SW is purely additive,
    // the site works fine without it (we don't ship an "install" prompt).
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(() => {});
      });
    }
  </script>
</body>
</html>
