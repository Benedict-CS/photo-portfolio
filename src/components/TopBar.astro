---
import type { PhotoView as Photo } from '~/lib/photos';

interface Props {
  photos: Photo[];
  active: 'map' | 'timeline' | 'trips' | 'favorites' | 'upload' | 'admin';
}
const { photos, active } = Astro.props;

const countries = new Set(
  photos.map((p) => p.country).filter((c) => c && c !== 'Unlocated')
);
const dates = photos.map((p) => p.datetime?.slice(0, 10) || '').filter(Boolean).sort();
const span = dates.length ? `${dates[0].slice(0, 4)}–${dates[dates.length - 1].slice(0, 4)}` : '';
---
<header id="topbar">
  <a class="brand" href="/">
    <span class="logo">📸</span>
    <span class="title">Photo Portfolio</span>
    <span class="stats">{photos.length} photos · {countries.size} countries · {span}</span>
  </a>
  <nav>
    <a href="/" class={active === 'map' ? 'active' : ''} title="Map">🗺️ <span class="nav-label">Map</span></a>
    <a href="/timeline" class={active === 'timeline' ? 'active' : ''} title="Timeline">📅 <span class="nav-label">Timeline</span></a>
    <a href="/trips" class={active === 'trips' ? 'active' : ''} title="Trips">✈️ <span class="nav-label">Trips</span></a>
    <a href="/favorites" class={active === 'favorites' ? 'active' : ''} title="Favorites">⭐</a>
    <a href="/upload" class={`admin-link edit-only${active === 'upload' ? ' active' : ''}`} title="Upload photos">📤</a>
    <a href="/admin" class={`admin-link edit-only${active === 'admin' ? ' active' : ''}`} title="Admin">⚙️</a>
    <button id="auth-btn" type="button" class="auth-btn" title="Sign in / out">
      <span class="auth-label">Sign in</span>
    </button>
  </nav>
</header>

<style is:global>
  #topbar .auth-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: 1px solid transparent;
    color: var(--muted);
    cursor: pointer;
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-family: inherit;
  }
  #topbar .auth-btn:hover { background: #f3f4f6; color: var(--text); }
  #topbar .auth-btn.logged-in { color: #1a8a3a; }

  #topbar .admin-link {
    font-size: 14px;
    padding: 5px 10px;
    border-radius: 6px;
    color: var(--muted);
  }
  #topbar .admin-link:hover {
    background: #f3f4f6;
    text-decoration: none;
    transform: scale(1.1);
  }

  /* Mobile: compress nav and hide stats / nav labels */
  @media (max-width: 720px) {
    #topbar { padding: 6px 10px; height: 44px; gap: 4px; }
    #topbar .brand .stats { display: none; }
    #topbar .brand { gap: 6px; min-width: 0; flex-shrink: 1; }
    #topbar .brand .title {
      font-size: 13px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    #topbar nav { gap: 2px; flex-shrink: 0; }
    #topbar nav a, #topbar .auth-btn { padding: 4px 7px; font-size: 12px; }
    #topbar nav a .nav-label { display: none; }
    #topbar .auth-btn .auth-label {
      max-width: 70px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }

  /* Very narrow phones: drop the brand TITLE so the nav has space. The
     logo (📸) stays as the home link affordance. */
  @media (max-width: 420px) {
    #topbar .brand .title { display: none; }
    #topbar nav a, #topbar .auth-btn { padding: 4px 5px; }
  }
</style>

<script>
  const TOKEN_KEY = 'photo-admin-token';

  function refreshBtn() {
    const btn = document.getElementById('auth-btn');
    const label = btn?.querySelector('.auth-label');
    if (!btn || !label) return;
    const has = !!localStorage.getItem(TOKEN_KEY);
    btn.classList.toggle('logged-in', has);
    label.textContent = has ? '🔒 Signed in' : '🔓 Sign in';
    document.body.classList.toggle('logged-in', has);
    document.body.classList.toggle('logged-out', !has);
  }

  async function onAuthClick() {
    const has = !!localStorage.getItem(TOKEN_KEY);
    if (has) {
      if (confirm('Sign out? You will be asked for the password again next time you edit.')) {
        localStorage.removeItem(TOKEN_KEY);
        refreshBtn();
        window.dispatchEvent(new CustomEvent('toast:show', { detail: { type: 'info', message: 'Signed out' } }));
      }
      return;
    }
    const pw = await window.promptPassword('Enter admin password');
    if (!pw) return;
    const r = await fetch('/api/metadata', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${pw}` },
      body: JSON.stringify({}),
    });
    if (r.status === 401) {
      window.dispatchEvent(new CustomEvent('toast:show', { detail: { type: 'error', message: 'Wrong password' } }));
      return;
    }
    localStorage.setItem(TOKEN_KEY, pw);
    refreshBtn();
    window.dispatchEvent(new CustomEvent('toast:show', { detail: { type: 'success', message: 'Signed in' } }));
  }

  // Astro's ClientRouter swaps the body on each navigation, which means a
  // listener bound to the old #auth-btn dies with the old DOM. Re-bind on
  // every `astro:page-load` so the new button is always live.
  function setup() {
    refreshBtn();
    const btn = document.getElementById('auth-btn');
    btn?.addEventListener('click', onAuthClick);
  }
  setup();
  document.addEventListener('astro:page-load', setup);
  window.addEventListener('storage', (e) => { if (e.key === TOKEN_KEY) refreshBtn(); });
  window.addEventListener('auth:changed', refreshBtn);
</script>
