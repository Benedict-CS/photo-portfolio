---
import type { PhotoView as Photo } from '~/lib/photos';

interface Props {
  photos: Photo[];
  active: 'map' | 'timeline' | 'trips' | 'favorites' | 'upload' | 'admin';
}
const { photos, active } = Astro.props;

const countries = new Set(
  photos.map((p) => p.country).filter((c) => c && c !== 'Unlocated')
);
const dates = photos.map((p) => p.datetime?.slice(0, 10) || '').filter(Boolean).sort();
const span = dates.length ? `${dates[0].slice(0, 4)}–${dates[dates.length - 1].slice(0, 4)}` : '';
// Pluralise the brand stats so video counts get their own callout (it's
// way more interesting than "31 photos" hiding a single clip).
const photoCount = photos.filter((p) => p.kind !== 'video').length;
const videoCount = photos.filter((p) => p.kind === 'video').length;
const countParts: string[] = [];
if (photoCount) countParts.push(`${photoCount} photo${photoCount === 1 ? '' : 's'}`);
if (videoCount) countParts.push(`${videoCount} video${videoCount === 1 ? '' : 's'}`);
const countLine = countParts.join(' · ');
---
<header id="topbar">
  <a class="brand" href="/">
    <span class="logo">📸</span>
    <span class="title">Photo Portfolio</span>
    <span class="stats">{countLine} · {countries.size} countries · {span}</span>
  </a>
  <nav>
    <a href="/" class={active === 'map' ? 'active' : ''} title="Map">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21 3 6"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
      <span class="nav-label">Map</span>
    </a>
    <a href="/timeline" class={active === 'timeline' ? 'active' : ''} title="Timeline">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <span class="nav-label">Timeline</span>
    </a>
    <a href="/trips" class={active === 'trips' ? 'active' : ''} title="Trips">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
      <span class="nav-label">Trips</span>
    </a>
    <a href="/favorites" class={active === 'favorites' ? 'active' : ''} title="Favorites">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    </a>
    <a href="/upload" class={`admin-link edit-only${active === 'upload' ? ' active' : ''}`} title="Upload photos">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
    </a>
    <a href="/admin" class={`admin-link edit-only${active === 'admin' ? ' active' : ''}`} title="Admin">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
    </a>
    <button id="auth-btn" type="button" class="auth-btn" title="Sign in / out">
      <span class="auth-label">Sign in</span>
    </button>
  </nav>
</header>

<style is:global>
  #topbar .auth-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: 1px solid transparent;
    color: var(--muted);
    cursor: pointer;
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-family: inherit;
  }
  #topbar .auth-btn:hover { background: #f3f4f6; color: var(--text); }
  #topbar .auth-btn.logged-in { color: #1a8a3a; }

  #topbar .admin-link {
    font-size: 14px;
    padding: 5px 10px;
    border-radius: 6px;
    color: var(--muted);
  }
  #topbar .admin-link:hover {
    background: #f3f4f6;
    text-decoration: none;
    transform: scale(1.1);
  }

  /* Mobile: compress nav and hide stats / nav labels */
  @media (max-width: 720px) {
    #topbar { padding: 6px 10px; height: 44px; gap: 4px; }
    #topbar .brand .stats { display: none; }
    #topbar .brand { gap: 6px; min-width: 0; flex-shrink: 1; }
    #topbar .brand .title {
      font-size: 13px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    #topbar nav { gap: 2px; flex-shrink: 0; }
    #topbar nav a, #topbar .auth-btn { padding: 4px 7px; font-size: 12px; }
    #topbar nav a .nav-label { display: none; }
    #topbar .auth-btn .auth-label {
      max-width: 70px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }

  /* Very narrow phones: drop the brand TITLE so the nav has space. The
     logo (📸) stays as the home link affordance. */
  @media (max-width: 420px) {
    #topbar .brand .title { display: none; }
    #topbar nav a, #topbar .auth-btn { padding: 4px 5px; }
  }
</style>

<script>
  const TOKEN_KEY = 'photo-admin-token';

  function refreshBtn() {
    const btn = document.getElementById('auth-btn');
    const label = btn?.querySelector('.auth-label');
    if (!btn || !label) return;
    const has = !!localStorage.getItem(TOKEN_KEY);
    btn.classList.toggle('logged-in', has);
    label.textContent = has ? '🔒 Signed in' : '🔓 Sign in';
    document.body.classList.toggle('logged-in', has);
    document.body.classList.toggle('logged-out', !has);
  }

  async function onAuthClick() {
    const has = !!localStorage.getItem(TOKEN_KEY);
    if (has) {
      if (confirm('Sign out? You will be asked for the password again next time you edit.')) {
        localStorage.removeItem(TOKEN_KEY);
        refreshBtn();
        window.dispatchEvent(new CustomEvent('toast:show', { detail: { type: 'info', message: 'Signed out' } }));
      }
      return;
    }
    const pw = await window.promptPassword('Enter admin password');
    if (!pw) return;
    const r = await fetch('/api/metadata', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${pw}` },
      body: JSON.stringify({}),
    });
    if (r.status === 401) {
      window.dispatchEvent(new CustomEvent('toast:show', { detail: { type: 'error', message: 'Wrong password' } }));
      return;
    }
    localStorage.setItem(TOKEN_KEY, pw);
    refreshBtn();
    window.dispatchEvent(new CustomEvent('toast:show', { detail: { type: 'success', message: 'Signed in' } }));
  }

  // Astro's ClientRouter swaps the body on each navigation, which means a
  // listener bound to the old #auth-btn dies with the old DOM. Re-bind on
  // every `astro:page-load` so the new button is always live.
  function setup() {
    refreshBtn();
    const btn = document.getElementById('auth-btn');
    btn?.addEventListener('click', onAuthClick);
  }
  setup();
  document.addEventListener('astro:page-load', setup);
  window.addEventListener('storage', (e) => { if (e.key === TOKEN_KEY) refreshBtn(); });
  window.addEventListener('auth:changed', refreshBtn);
</script>
