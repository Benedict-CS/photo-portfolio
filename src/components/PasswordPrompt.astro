---
// Custom password input modal (masks with •••, unlike native prompt).
// Use anywhere with the global helper:
//   const pw = await window.promptPassword('請輸入管理員密碼');
//   if (pw) { ... } else { // user cancelled }
---
<div id="pw-modal" hidden>
  <div class="pw-card">
    <h3 id="pw-title">請輸入管理員密碼</h3>
    <input
      id="pw-input"
      type="password"
      autocomplete="current-password"
      placeholder="密碼"
    />
    <div class="pw-actions">
      <button id="pw-cancel" type="button" class="pw-secondary">取消</button>
      <button id="pw-ok" type="button" class="pw-primary">確認</button>
    </div>
  </div>
</div>

<style is:global>
  #pw-modal {
    position: fixed;
    inset: 0;
    z-index: 10001;
    background: rgba(0,0,0,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
    opacity: 1;
    transition: opacity 0.18s;
  }
  #pw-modal[hidden] {
    display: flex;
    opacity: 0;
    pointer-events: none;
  }
  #pw-modal .pw-card {
    background: white;
    color: var(--text);
    border-radius: 12px;
    width: min(360px, 90vw);
    padding: 22px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  #pw-modal h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }
  #pw-modal input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 14px;
    font-family: inherit;
    box-sizing: border-box;
  }
  #pw-modal input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(3, 102, 214, 0.15);
  }
  #pw-modal .pw-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }
  #pw-modal button {
    padding: 8px 18px;
    border-radius: 6px;
    border: 1px solid transparent;
    cursor: pointer;
    font-size: 13px;
    font-family: inherit;
  }
  #pw-modal .pw-secondary {
    background: white;
    border-color: var(--border);
    color: var(--text);
  }
  #pw-modal .pw-secondary:hover { background: #f3f4f6; }
  #pw-modal .pw-primary {
    background: var(--accent);
    color: white;
  }
  #pw-modal .pw-primary:hover { background: #024fa1; }
</style>

<script>
  const modal = document.getElementById('pw-modal')!;
  const input = document.getElementById('pw-input') as HTMLInputElement;
  const title = document.getElementById('pw-title')!;
  const okBtn = document.getElementById('pw-ok')!;
  const cancelBtn = document.getElementById('pw-cancel')!;

  let pending: ((v: string | null) => void) | null = null;

  function close(value: string | null) {
    modal.hidden = true;
    const cb = pending;
    pending = null;
    input.value = '';
    cb?.(value);
  }

  okBtn.addEventListener('click', () => close(input.value));
  cancelBtn.addEventListener('click', () => close(null));
  modal.addEventListener('click', (e) => { if (e.target === modal) close(null); });
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); close(input.value); }
    else if (e.key === 'Escape') { e.preventDefault(); close(null); }
  });

  // Expose globally so any inline script can call it.
  (window as any).promptPassword = (message?: string): Promise<string | null> => {
    if (pending) pending(null);
    title.textContent = message || '請輸入管理員密碼';
    modal.hidden = false;
    setTimeout(() => input.focus(), 30);
    return new Promise((resolve) => { pending = resolve; });
  };
</script>
