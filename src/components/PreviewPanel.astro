---
// Minimalist photo preview panel — opens when a marker is clicked.
// Shows: photo, datetime overlay, download button. Nothing else.
---
<div id="preview" aria-hidden="true">
  <button class="close" type="button" aria-label="Close">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <a id="preview-download" class="download" href="#" download title="Download original">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
  </a>
  <a id="preview-edit" class="edit edit-only" href="#" title="Edit location / date">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
  </a>
  <img class="hero" id="preview-hero" alt="" />
  <div class="datetime" id="preview-datetime"></div>
</div>

<script>
  const panel = document.getElementById('preview')!;
  const hero = document.getElementById('preview-hero');
  const datetimeEl = document.getElementById('preview-datetime')!;
  const downloadEl = document.getElementById('preview-download');
  const editEl = document.getElementById('preview-edit');

  let currentPhoto = null;

  function open(photo: any) {
    currentPhoto = photo;
    hero.src = photo.thumbs.l;
    hero.alt = photo.album || photo.file;
    const dt = photo.datetime ? photo.datetime.slice(0, 10) : '';
    datetimeEl.textContent = dt ? `📅 ${dt}` : '';
    datetimeEl.style.display = dt ? '' : 'none';
    downloadEl.href = photo.originalUrl;
    // Only show the edit shortcut for photos that have something the user can fill in.
    if (photo.editable) {
      editEl.href = `/photos/${photo.id}?pin=1`;
      editEl.style.display = '';
    } else {
      editEl.style.display = 'none';
    }
    panel.classList.add('show');
    panel.setAttribute('aria-hidden', 'false');
  }

  function close() {
    panel.classList.remove('show');
    panel.setAttribute('aria-hidden', 'true');
    currentPhoto = null;
  }

  panel.querySelector('.close')!.addEventListener('click', close);
  hero.addEventListener('click', () => {
    if (!currentPhoto) return;
    // Single source of truth — same detail page everywhere.
    window.location.href = `/photos/${currentPhoto.id}`;
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel.classList.contains('show')) close();
  });

  window.addEventListener('preview:open', (e) => open(e.detail.photo));
  window.addEventListener('preview:close', close);
</script>
