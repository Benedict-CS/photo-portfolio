---
// Floating photo preview — opens when a marker (map) or a cell (timeline)
// is clicked. Includes a dark scrim behind the panel so the eye lands on
// the photo, prev/next navigation, keyboard support, and a loading
// state for the hero image while the larger thumb downloads.
//
// Consumers dispatch `preview:open` with detail = { photo, photos?, index? }.
// When photos[] + index are supplied, the prev/next arrows + Arrow-key
// shortcuts step through the set; otherwise they hide.
---
<div id="preview-backdrop" hidden></div>
<div id="preview" aria-hidden="true">
  <button class="close" type="button" aria-label="Close">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <a id="preview-download" class="download" href="#" download title="Download original">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
  </a>
  <a id="preview-edit" class="edit edit-only" href="#" title="Edit location / date">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
  </a>

  <button id="preview-prev" class="nav-arrow prev" type="button" aria-label="Previous photo" hidden>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button id="preview-next" class="nav-arrow next" type="button" aria-label="Next photo" hidden>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><polyline points="9 18 15 12 9 6"/></svg>
  </button>

  {/* Loading spinner shown while the hero is downloading the L thumb. */}
  <div id="preview-spinner" class="spinner" hidden>
    <div class="spinner-ring"></div>
  </div>

  <img class="hero" id="preview-hero" alt="" decoding="async" />
  <div class="datetime" id="preview-datetime"></div>

  {/* Open-detail-page CTA — for users who want the canonical URL or to
      edit metadata. */}
  <a id="preview-open-detail" class="open-detail" href="#">
    Open detail page
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
  </a>
</div>

<style is:global>
  /* ---- Scrim behind the floating preview ---- */
  #preview-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }
  #preview-backdrop[hidden] { display: none; }
  #preview-backdrop.show {
    opacity: 1;
    pointer-events: auto;
  }

  /* ---- Hero load fade ---- */
  #preview .hero {
    opacity: 0;
    transition: opacity 0.28s ease;
  }
  #preview .hero.loaded { opacity: 1; }

  /* ---- Loading spinner ---- */
  #preview .spinner {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 6;
    pointer-events: none;
  }
  #preview .spinner[hidden] { display: none; }
  #preview .spinner-ring {
    width: 38px;
    height: 38px;
    border: 3px solid rgba(255, 255, 255, 0.25);
    border-top-color: white;
    border-radius: 50%;
    animation: preview-spin 0.85s linear infinite;
  }
  @keyframes preview-spin {
    to { transform: rotate(360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    #preview .spinner-ring { animation: none; }
  }

  /* ---- Prev / Next arrows ---- */
  #preview .nav-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    color: white;
    border: none;
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    transition: background 0.15s, transform 0.15s, opacity 0.15s;
  }
  #preview .nav-arrow[hidden] { display: none; }
  #preview .nav-arrow:hover {
    background: rgba(0, 0, 0, 0.85);
    transform: translateY(-50%) scale(1.08);
  }
  #preview .nav-arrow:active { transform: translateY(-50%) scale(0.96); }
  #preview .nav-arrow.prev { left: 10px; }
  #preview .nav-arrow.next { right: 10px; }

  /* ---- Open-detail CTA ---- */
  #preview .open-detail {
    position: absolute;
    bottom: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--text);
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    backdrop-filter: blur(6px);
    transition: background 0.15s, transform 0.15s;
  }
  #preview .open-detail:hover {
    background: white;
    text-decoration: none;
    transform: scale(1.04);
  }

  /* Mobile arrows sit above the bottom-sheet image. */
  @media (max-width: 720px) {
    #preview .nav-arrow {
      top: auto;
      bottom: 60px;
      transform: none;
    }
    #preview .nav-arrow:hover { transform: scale(1.08); }
    #preview .nav-arrow:active { transform: scale(0.96); }
    #preview .nav-arrow.prev { left: 12px; }
    #preview .nav-arrow.next { right: 12px; }
  }
</style>

<script>
  // ClientRouter swaps the body on each navigation, so DOM refs and
  // listeners attached at module load go stale. Re-bind on every
  // astro:page-load.
  let cleanupPreview: (() => void) | null = null;
  let currentPhoto: any = null;
  let currentPhotos: any[] = [];
  let currentIndex = -1;

  function setup() {
    cleanupPreview?.();
    const ac = new AbortController();
    const signal = ac.signal;
    cleanupPreview = () => ac.abort();

    const panel = document.getElementById('preview');
    const backdrop = document.getElementById('preview-backdrop');
    const hero = document.getElementById('preview-hero') as HTMLImageElement | null;
    const datetimeEl = document.getElementById('preview-datetime');
    const downloadEl = document.getElementById('preview-download') as HTMLAnchorElement | null;
    const editEl = document.getElementById('preview-edit') as HTMLAnchorElement | null;
    const openDetailEl = document.getElementById('preview-open-detail') as HTMLAnchorElement | null;
    const prevBtn = document.getElementById('preview-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('preview-next') as HTMLButtonElement | null;
    const spinner = document.getElementById('preview-spinner');
    if (!panel || !backdrop || !hero || !datetimeEl || !downloadEl || !editEl
        || !openDetailEl || !prevBtn || !nextBtn || !spinner) return;

    function syncArrows() {
      const haveSet = currentPhotos.length > 1 && currentIndex >= 0;
      prevBtn.hidden = !haveSet;
      nextBtn.hidden = !haveSet;
      if (!haveSet) return;
      // Disable (not hide) the edges so the buttons don't jump around.
      prevBtn.disabled = currentIndex <= 0;
      nextBtn.disabled = currentIndex >= currentPhotos.length - 1;
      prevBtn.style.opacity = prevBtn.disabled ? '0.35' : '';
      nextBtn.style.opacity = nextBtn.disabled ? '0.35' : '';
    }

    function renderPhoto(photo: any) {
      currentPhoto = photo;
      hero.classList.remove('loaded');
      spinner.hidden = false;
      // Set src AFTER hiding `loaded`/showing spinner so the fade-in
      // sequence fires whenever the new image actually paints.
      hero.src = photo.thumbs?.l ?? '';
      hero.alt = photo.album || photo.file || '';
      const dt = photo.datetime ? photo.datetime.slice(0, 10) : '';
      datetimeEl.textContent = dt;
      datetimeEl.style.display = dt ? '' : 'none';
      downloadEl.href = photo.originalUrl ?? '#';
      openDetailEl.href = `/photos/${photo.id}`;
      if (photo.editable) {
        editEl.href = `/photos/${photo.id}?pin=1`;
        editEl.style.display = '';
      } else {
        editEl.style.display = 'none';
      }
      // If the image is already in the cache the load event fires
      // before our listener attaches — check the complete flag too.
      if (hero.complete && hero.naturalWidth > 0) {
        hero.classList.add('loaded');
        spinner.hidden = true;
      }
    }

    function open(detail: any) {
      // Consumers may pass either { photo } or { photos, index }.
      // The richer form drives prev/next.
      if (Array.isArray(detail?.photos) && typeof detail.index === 'number') {
        currentPhotos = detail.photos;
        currentIndex = Math.max(0, Math.min(detail.index, detail.photos.length - 1));
        renderPhoto(detail.photos[currentIndex]);
      } else if (detail?.photo) {
        currentPhotos = [];
        currentIndex = -1;
        renderPhoto(detail.photo);
      } else {
        return;
      }
      syncArrows();
      backdrop.hidden = false;
      void backdrop.offsetWidth; // force reflow → CSS transition fires
      backdrop.classList.add('show');
      panel.classList.add('show');
      panel.setAttribute('aria-hidden', 'false');
    }

    function close() {
      panel.classList.remove('show');
      panel.setAttribute('aria-hidden', 'true');
      backdrop.classList.remove('show');
      setTimeout(() => { backdrop.hidden = true; }, 220);
      currentPhoto = null;
      currentPhotos = [];
      currentIndex = -1;
    }

    function step(delta: number) {
      if (currentPhotos.length < 2) return;
      const next = currentIndex + delta;
      if (next < 0 || next >= currentPhotos.length) return;
      currentIndex = next;
      renderPhoto(currentPhotos[currentIndex]);
      syncArrows();
    }

    prevBtn.addEventListener('click', () => step(-1), { signal });
    nextBtn.addEventListener('click', () => step(1), { signal });

    hero.addEventListener('load', () => {
      hero.classList.add('loaded');
      spinner.hidden = true;
    }, { signal });
    hero.addEventListener('error', () => {
      spinner.hidden = true;
    }, { signal });

    panel.querySelector('.close')?.addEventListener('click', close, { signal });
    backdrop.addEventListener('click', close, { signal });
    hero.addEventListener('click', () => {
      // Tap on the photo itself — open the canonical detail page.
      if (!currentPhoto) return;
      window.location.href = `/photos/${currentPhoto.id}`;
    }, { signal });

    document.addEventListener('keydown', (e) => {
      if (!panel.classList.contains('show')) return;
      // Ignore when typing in inputs (none in preview today, but safe).
      const tag = (e.target as HTMLElement)?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') { e.preventDefault(); step(-1); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); step(1); }
    }, { signal });

    window.addEventListener('preview:open', (e: any) => open(e.detail), { signal });
    window.addEventListener('preview:close', close, { signal });
  }
  setup();
  document.addEventListener('astro:page-load', setup);
</script>
