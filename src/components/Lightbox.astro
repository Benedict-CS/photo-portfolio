---
// Lightbox with prev/next navigation.
// Open with:
//   window.dispatchEvent(new CustomEvent('lightbox:open', {
//     detail: { srcs: ['url1', 'url2', ...], index: 0 }
//   }));
// Legacy single-item open also supported: { src, caption }.
---
<div id="lightbox" aria-hidden="true">
  <button class="lb-close" type="button" aria-label="關閉">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <button class="lb-nav lb-prev" type="button" aria-label="上一張">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="lb-nav lb-next" type="button" aria-label="下一張">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <img id="lightbox-img" alt="" />
  <div class="lb-counter" id="lightbox-counter"></div>
  <div class="lb-info" id="lightbox-info"></div>
  <button id="lightbox-fav" class="lb-fav" type="button" title="收藏 (F)" aria-pressed="false">☆</button>
  <a id="lightbox-detail" class="lb-detail edit-only" href="#" title="開詳細頁 (編輯位置/日期)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
    <span>編輯位置/日期</span>
  </a>
</div>

<script>
  const lb = document.getElementById('lightbox')!;
  const img = document.getElementById('lightbox-img') as HTMLImageElement;
  const counter = document.getElementById('lightbox-counter')!;
  const prevBtn = lb.querySelector('.lb-prev') as HTMLButtonElement;
  const nextBtn = lb.querySelector('.lb-next') as HTMLButtonElement;
  const closeBtn = lb.querySelector('.lb-close') as HTMLButtonElement;

  /** Per-photo metadata for the info overlay + ⭐ + edit link. */
  interface LbPhoto {
    src: string;
    id?: string;
    path?: string;
    editable?: boolean;
    country?: string;
    countryCode?: string;
    datetime?: string;
    camera?: string;
    favorite?: boolean;
  }
  let items: LbPhoto[] = [];
  let idx = 0;

  // ---- Zoom & pan state ----
  let scale = 1;
  let tx = 0;   // translateX in px
  let ty = 0;   // translateY in px
  let dragging = false;
  let dragStartX = 0, dragStartY = 0, tx0 = 0, ty0 = 0;

  function applyTransform() {
    img.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
    img.style.cursor = scale > 1 ? (dragging ? 'grabbing' : 'grab') : 'default';
  }
  function resetTransform() {
    scale = 1; tx = 0; ty = 0;
    applyTransform();
  }

  function flag(code: string) {
    if (!code || code.length !== 2) return '📍';
    return String.fromCodePoint(
      ...[...code.toLowerCase()].map((c) => 0x1f1e6 + (c.charCodeAt(0) - 97))
    );
  }

  function renderInfo(it: LbPhoto) {
    const info = document.getElementById('lightbox-info')!;
    const bits: string[] = [];
    if (it.country) {
      bits.push(`<span class="flag">${flag(it.countryCode || '')}</span><span>${it.country}</span>`);
    }
    if (it.datetime) bits.push(`<span>${it.datetime.slice(0, 10)}</span>`);
    if (it.camera) bits.push(`<span>📷 ${it.camera}</span>`);
    // Use the same "· dot" separator as the detail page info bar.
    info.innerHTML = bits.join('<span class="dot">·</span>');
    info.style.display = bits.length ? '' : 'none';

    const fav = document.getElementById('lightbox-fav') as HTMLButtonElement;
    fav.textContent = it.favorite ? '⭐' : '☆';
    fav.classList.toggle('on', !!it.favorite);
    fav.setAttribute('aria-pressed', String(!!it.favorite));
    fav.style.display = it.path ? '' : 'none';
  }

  function show(i: number) {
    if (i < 0 || i >= items.length) return;
    idx = i;
    resetTransform();
    const it = items[i];
    const newSrc = it.src;
    if (img.src && img.src !== newSrc) {
      img.classList.add('lb-fading');
      const onLoaded = () => {
        img.classList.remove('lb-fading');
        img.removeEventListener('load', onLoaded);
      };
      const preloader = new Image();
      preloader.onload = () => {
        img.src = newSrc;
        img.addEventListener('load', onLoaded, { once: true });
      };
      preloader.src = newSrc;
    } else {
      img.src = newSrc;
    }
    counter.textContent = items.length > 1 ? `${i + 1} / ${items.length}` : '';
    prevBtn.style.visibility = i > 0 ? 'visible' : 'hidden';
    nextBtn.style.visibility = i < items.length - 1 ? 'visible' : 'hidden';
    const detail = document.getElementById('lightbox-detail') as HTMLAnchorElement;
    if (it.id && it.editable) {
      detail.href = `/photos/${it.id}?pin=1`;
      detail.style.display = '';
    } else {
      detail.style.display = 'none';
    }
    renderInfo(it);
  }

  function open(list: LbPhoto[], startIndex = 0) {
    if (!list.length) return;
    items = list;
    show(startIndex);
    lb.classList.add('show');
    lb.setAttribute('aria-hidden', 'false');
  }

  // ---- ⭐ Favorite toggle (only when path provided + logged in) ----
  const TOKEN_KEY = 'photo-admin-token';
  async function toggleFavorite() {
    const it = items[idx];
    if (!it || !it.path) return;
    const next = !it.favorite;
    const fav = document.getElementById('lightbox-fav') as HTMLButtonElement;
    // Optimistic
    it.favorite = next;
    fav.textContent = next ? '⭐' : '☆';
    fav.classList.toggle('on', next);
    fav.setAttribute('aria-pressed', String(next));
    try {
      const headers: Record<string, string> = { 'Content-Type': 'application/json' };
      const tok = localStorage.getItem(TOKEN_KEY);
      if (tok) headers['Authorization'] = `Bearer ${tok}`;
      const res = await fetch('/api/metadata', {
        method: 'POST',
        headers,
        body: JSON.stringify({ path: it.path, favorite: next }),
      });
      if (res.status === 401) throw new Error('需要登入');
      const data = await res.json();
      if (!data.ok) throw new Error(data.error || 'save failed');
      window.dispatchEvent(new CustomEvent('toast:show', {
        detail: { type: 'success', message: next ? '⭐ 加入收藏' : '已取消收藏' },
      }));
    } catch (err: any) {
      // Rollback
      it.favorite = !next;
      fav.textContent = !next ? '⭐' : '☆';
      fav.classList.toggle('on', !next);
      fav.setAttribute('aria-pressed', String(!next));
      window.dispatchEvent(new CustomEvent('toast:show', {
        detail: { type: 'error', message: `失敗:${err.message || err}` },
      }));
    }
  }
  document.getElementById('lightbox-fav')?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleFavorite();
  });

  function close() {
    lb.classList.remove('show');
    lb.setAttribute('aria-hidden', 'true');
    img.src = '';
    items = [];
  }

  function next() { if (idx < items.length - 1) show(idx + 1); }
  function prev() { if (idx > 0) show(idx - 1); }

  prevBtn.addEventListener('click', (e) => { e.stopPropagation(); prev(); });
  nextBtn.addEventListener('click', (e) => { e.stopPropagation(); next(); });
  closeBtn.addEventListener('click', (e) => { e.stopPropagation(); close(); });
  // Click background closes; click image does nothing (don't accidentally close).
  lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
  img.addEventListener('click', (e) => e.stopPropagation());

  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('show')) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowRight') next();
    else if (e.key === 'ArrowLeft') prev();
  });

  window.addEventListener('lightbox:open', (e: any) => {
    const d = e.detail || {};
    // New shape: { items: LbPhoto[], index }
    if (Array.isArray(d.items)) {
      open(d.items, d.index ?? 0);
      return;
    }
    // Legacy: { srcs, ids, editable, index }
    if (Array.isArray(d.srcs)) {
      const list = d.srcs.map((s: string, i: number) => ({
        src: s,
        id: d.ids?.[i],
        editable: d.editable?.[i],
      }));
      open(list, d.index ?? 0);
      return;
    }
    // Legacy single: { src, caption }
    if (d.src) open([{ src: d.src }], 0);
  });

  // ---- Wheel = zoom toward cursor ----
  lb.addEventListener('wheel', (e) => {
    if (!lb.classList.contains('show')) return;
    e.preventDefault();
    const rect = img.getBoundingClientRect();
    const cx = e.clientX - (rect.left + rect.width / 2);
    const cy = e.clientY - (rect.top + rect.height / 2);
    const oldScale = scale;
    const factor = e.deltaY < 0 ? 1.15 : 1 / 1.15;
    scale = Math.max(1, Math.min(8, scale * factor));
    // Keep the point under the cursor stationary by adjusting translate.
    const k = scale / oldScale;
    tx = (tx - cx) * k + cx;
    ty = (ty - cy) * k + cy;
    if (scale === 1) { tx = 0; ty = 0; }
    applyTransform();
  }, { passive: false });

  // ---- Click/drag to pan when zoomed ----
  img.addEventListener('mousedown', (e) => {
    if (scale <= 1) return;
    dragging = true;
    dragStartX = e.clientX; dragStartY = e.clientY;
    tx0 = tx; ty0 = ty;
    applyTransform();
    e.preventDefault();
  });
  window.addEventListener('mousemove', (e) => {
    if (!dragging) return;
    tx = tx0 + (e.clientX - dragStartX);
    ty = ty0 + (e.clientY - dragStartY);
    applyTransform();
  });
  window.addEventListener('mouseup', () => {
    if (!dragging) return;
    dragging = false;
    applyTransform();
  });

  // ---- Double-click toggles 1x / 2.5x ----
  img.addEventListener('dblclick', (e) => {
    if (scale > 1) { resetTransform(); }
    else {
      const rect = img.getBoundingClientRect();
      const cx = e.clientX - (rect.left + rect.width / 2);
      const cy = e.clientY - (rect.top + rect.height / 2);
      scale = 2.5;
      tx = -cx * 1.5;
      ty = -cy * 1.5;
      applyTransform();
    }
  });

  // ---- Touch pinch zoom ----
  let touchDist0 = 0, touchScale0 = 1;
  let touchPanX = 0, touchPanY = 0, touchPanX0 = 0, touchPanY0 = 0;
  lb.addEventListener('touchstart', (e) => {
    if (e.touches.length === 2) {
      const dx = e.touches[0].clientX - e.touches[1].clientX;
      const dy = e.touches[0].clientY - e.touches[1].clientY;
      touchDist0 = Math.hypot(dx, dy);
      touchScale0 = scale;
    } else if (e.touches.length === 1 && scale > 1) {
      touchPanX = e.touches[0].clientX;
      touchPanY = e.touches[0].clientY;
      touchPanX0 = tx; touchPanY0 = ty;
    }
  }, { passive: true });
  lb.addEventListener('touchmove', (e) => {
    if (e.touches.length === 2) {
      e.preventDefault();
      const dx = e.touches[0].clientX - e.touches[1].clientX;
      const dy = e.touches[0].clientY - e.touches[1].clientY;
      const dist = Math.hypot(dx, dy);
      scale = Math.max(1, Math.min(8, touchScale0 * (dist / touchDist0)));
      if (scale === 1) { tx = 0; ty = 0; }
      applyTransform();
    } else if (e.touches.length === 1 && scale > 1) {
      tx = touchPanX0 + (e.touches[0].clientX - touchPanX);
      ty = touchPanY0 + (e.touches[0].clientY - touchPanY);
      applyTransform();
    }
  }, { passive: false });
</script>
