---
/**
 * Global toast.
 * Use:
 *   window.dispatchEvent(new CustomEvent('toast:show', {
 *     detail: { type: 'success' | 'error' | 'info', message: 'Saved' }
 *   }));
 */
---
<div id="toast-stack" aria-live="polite"></div>

<style is:global>
  #toast-stack {
    position: fixed;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10000;
    display: flex;
    flex-direction: column;
    gap: 8px;
    pointer-events: none;
    /* Cap the centred stack so a long message can't push past either edge
       on narrow viewports. The min-width on .toast remains the soft floor. */
    max-width: calc(100vw - 24px);
  }
  .toast {
    pointer-events: auto;
    background: rgba(20, 20, 20, 0.92);
    color: white;
    font-size: 14px;
    padding: 10px 18px;
    border-radius: 999px;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: min(200px, 100%);
    max-width: 100%;
    overflow-wrap: anywhere;
    justify-content: center;
    transform: translateY(-8px);
    opacity: 0;
    transition: transform 0.22s cubic-bezier(0.2, 0.9, 0.3, 1), opacity 0.18s;
  }
  .toast.show { transform: translateY(0); opacity: 1; }
  .toast.success { background: rgba(20, 100, 50, 0.92); }
  .toast.error { background: rgba(170, 40, 40, 0.92); }
  .toast .icon { font-size: 16px; line-height: 1; }
</style>

<script>
  // Resolve the stack at toast time instead of script load — ClientRouter
  // swaps the DOM on each navigation, so caching the original element
  // would mean toasts dispatched on later pages have nowhere to land.
  function showToast(type: string, message: string, ttl = 2400) {
    const stack = document.getElementById('toast-stack');
    if (!stack) return;
    const el = document.createElement('div');
    el.className = `toast ${type}`;
    // Build via DOM APIs — never interpolate user-controlled `message`
    // into an innerHTML string, or a malicious toast dispatch could XSS.
    const iconChar = type === 'success' ? '✓' : type === 'error' ? '⚠' : '·';
    const iconEl = document.createElement('span');
    iconEl.className = 'icon';
    iconEl.textContent = iconChar;
    const textEl = document.createElement('span');
    textEl.textContent = message;
    el.append(iconEl, textEl);
    stack.appendChild(el);
    requestAnimationFrame(() => el.classList.add('show'));
    setTimeout(() => {
      el.classList.remove('show');
      setTimeout(() => el.remove(), 250);
    }, ttl);
  }
  window.addEventListener('toast:show', (e) => {
    const d = e.detail || {};
    showToast(d.type || 'info', d.message || '', d.ttl);
  });
</script>
