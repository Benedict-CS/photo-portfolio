{
  "name": "photo-portfolio",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "vendor": "node scripts/copy-vendor.mjs",
    "build": "node scripts/copy-vendor.mjs && node scripts/preserve-db.mjs save && astro build && node scripts/preserve-db.mjs restore",
    "preview": "astro preview",
    "sync": "astro db execute scripts/sync.mjs",
    "organize": "astro db execute scripts/organize.mjs",
    "predeploy": "npm run sync && npm run build",
    "backup": "node scripts/backup.mjs",
    "verify-backup": "node scripts/verify-backup.mjs"
  },
  "dependencies": {
    "@astrojs/db": "^0.14.14",
    "@astrojs/node": "^9.5.5",
    "@fontsource/inter": "^5.2.8",
    "astro": "^5.0.0",
    "dotenv": "^17.4.2",
    "exifr": "^7.1.3",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "sharp": "^0.33.5",
    "webdav": "^5.10.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/leaflet.markercluster": "^1.5.4",
    "chokidar": "^4.0.1"
  }
}
